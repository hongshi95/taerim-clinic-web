---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Header from '~/components/layout/Header.astro';
import Footer from '~/components/layout/Footer.astro';
import Breadcrumb from '~/components/layout/Breadcrumb.astro';
import ArticleSchema from '~/components/seo/ArticleSchema.astro';
import BreadcrumbSchema from '~/components/seo/BreadcrumbSchema.astro';
import HowToSchema from '~/components/seo/HowToSchema.astro';
import CitationsSchema from '~/components/seo/CitationsSchema.astro';
import FAQSchema from '~/components/seo/FAQSchema.astro';
import QuickAnswer from '~/components/content/QuickAnswer.astro';
import FAQSection from '~/components/content/FAQSection.astro';
import AuthorBio from '~/components/content/AuthorBio.astro';
import Citations from '~/components/content/Citations.astro';
import RelatedPosts from '~/components/content/RelatedPosts.astro';
import MobileCtaBar from '~/components/layout/MobileCtaBar.astro';
import SocialSidebar from '~/components/layout/SocialSidebar.astro';
import { SITE, CLINIC } from '~/consts';

interface FAQ {
  q: string;
  a: string;
}

interface HowToStep {
  name: string;
  text: string;
  image?: string;
}

interface Citation {
  claim: string;
  source: string;
  url?: string;
}

interface RelatedPost {
  url: string;
  title: string;
  summary?: string;
  cat?: string;
}

interface Props {
  title: string;
  description: string;
  slug: string;
  coverImage?: string;
  coverImageAlt?: string;
  ogImage?: string; // 공유 대표 이미지 (없으면 coverImage, 그것도 없으면 사이트 기본). 본문 인라인 이미지와 분리
  publishedAt: string;
  modifiedAt?: string;
  authorName: string;
  authorSlug: string;
  authorBio: string;
  authorAvatarUrl?: string;
  authorExpertise?: string[];
  categoryName: string;
  categorySlug: string;
  readingMinutes: number;
  quickAnswer: string;
  quickAnswerBullets?: string[];
  faqs?: FAQ[];
  wordCount?: number;
  entities?: string[];
  schemaType?: 'Article' | 'HowTo' | 'Review' | 'FAQPage';
  howtoSteps?: HowToStep[];
  howtoTotalTime?: string;
  citations?: Citation[];
  relatedPosts?: RelatedPost[];
  noIndex?: boolean;
}

const {
  title,
  description,
  slug,
  coverImage,
  coverImageAlt,
  ogImage,
  publishedAt,
  modifiedAt,
  authorName,
  authorSlug,
  authorBio,
  authorAvatarUrl,
  authorExpertise,
  categoryName,
  categorySlug,
  readingMinutes,
  quickAnswer,
  quickAnswerBullets,
  faqs = [],
  wordCount,
  entities = [],
  schemaType = 'Article',
  howtoSteps,
  howtoTotalTime,
  citations = [],
  relatedPosts = [],
  noIndex = false,
} = Astro.props;

// 글 끝 CTA를 검색 의도(카테고리)에 맞춰 변주 - 효과 단정 없이 사실(보험/절차/상담) 기반.
// 교통사고 독자(사고 직후, 최고 의도)와 미용 독자에게 같은 문구를 쓰면 전환을 놓침.
const CTA_COPY: Record<string, { heading: string; body: string }> = {
  accident: {
    heading: '교통사고 후 통증, 자동차보험으로 진료받을 수 있습니다',
    body: '자동차손해배상보장법에 따라 보험사 사고접수번호만 있으면 본인부담금 없이(원칙) 추나·약침·한약 진료가 가능합니다. 증상이 며칠 뒤 나타나는 경우도 많아 사고 후 빠른 검진을 권합니다.',
  },
  pain: {
    heading: '통증이 계속된다면 원인 확인이 먼저입니다',
    body: '같은 부위 통증도 원인은 사람마다 다릅니다. 진료를 통해 상태를 확인하고 침·추나·약침 등 치료 방향을 안내받으실 수 있습니다.',
  },
  diet: {
    heading: '한방 다이어트, 체질 확인부터 시작하세요',
    body: '같은 처방도 체질에 따라 반응이 다릅니다(개인차). 진료 상담으로 본인 체질과 생활 패턴에 맞는 관리 방향을 확인해 보세요.',
  },
  constitution: {
    heading: '내 체질에 맞는 보약이 궁금하다면',
    body: '보약·공진단·경옥고는 체질과 몸 상태에 따라 처방이 달라집니다. 진료 상담을 통해 확인하실 수 있습니다.',
  },
  pediatric: {
    heading: '아이 상태, 진료로 정확히 확인하세요',
    body: '아이마다 성장 속도와 체질이 다릅니다. 진료를 통해 아이에게 맞는 관리 방향을 안내받으실 수 있습니다.',
  },
  beauty: {
    heading: '매선·한방 미용, 상담 후 결정하세요',
    body: '시술 범위와 비용은 상태에 따라 달라집니다. 비급여 진료비용은 상담 시 안내받으실 수 있습니다.',
  },
};
const ctaCopy = CTA_COPY[categorySlug] ?? {
  heading: '궁금한 점이 있으신가요?',
  body: '본 글은 일반적인 의료 정보입니다. 정확한 진단·처방은 진료를 통해 이뤄집니다. 예약·상담 환영합니다.',
};

const canonicalPath = `/${categorySlug}/${slug}/`;
const modified = modifiedAt ?? publishedAt;
const pubDate = new Date(publishedAt).toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const modDate =
  modifiedAt && modifiedAt !== publishedAt
    ? new Date(modifiedAt).toLocaleDateString('ko-KR', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      })
    : null;
---

<BaseLayout
  title={title}
  description={description}
  type="article"
  image={ogImage ?? coverImage}
  publishedAt={publishedAt}
  modifiedAt={modified}
  author={authorName}
  canonicalPath={canonicalPath}
  noIndex={noIndex}
>
  <slot name="head" slot="head">
    <ArticleSchema
      title={title}
      description={description}
      slug={slug}
      coverImage={ogImage ?? coverImage}
      publishedAt={publishedAt}
      modifiedAt={modified}
      authorName={authorName}
      authorSlug={authorSlug}
      categoryName={categoryName}
      categorySlug={categorySlug}
      entities={entities}
      wordCount={wordCount}
    />
    <BreadcrumbSchema
      items={[
        { name: '홈', href: '/' },
        { name: categoryName, href: `/${categorySlug}/` },
        { name: title, href: canonicalPath },
      ]}
    />
    {schemaType === 'HowTo' && howtoSteps && howtoSteps.length > 0 && (
      <HowToSchema
        name={title}
        description={description}
        totalTime={howtoTotalTime}
        steps={howtoSteps}
      />
    )}
    {citations.length > 0 && (
      <CitationsSchema
        citations={citations}
        articleUrl={`${SITE.url}${canonicalPath}`}
        articleTitle={title}
      />
    )}
    {faqs && faqs.length > 0 && <FAQSchema faqs={faqs} />}
  </slot>

  <Header />

  <Breadcrumb
    items={[
      { name: categoryName, href: `/${categorySlug}/` },
      { name: title, href: canonicalPath },
    ]}
  />

  <main class="v-container py-8">
    <article class="v-prose">
      <!-- 카테고리 태그 -->
      <div class="not-prose mb-4">
        <a
          href={`/${categorySlug}/`}
          class="inline-flex items-center gap-1 px-3 py-1 text-xs font-medium rounded-full bg-deok-100 text-deok-700 hover:bg-deok-200"
        >
          {categoryName}
        </a>
      </div>

      <!-- 제목 + 메타 -->
      <h1 class="mb-4">{title}</h1>

      <div class="not-prose flex items-center flex-wrap gap-x-4 gap-y-1 text-sm text-gray-500 mb-8 pb-6 border-b border-gray-100">
        <a href={`/about/author/${authorSlug}`} rel="author" class="hover:text-deok-600 font-medium">
          {authorName}
        </a>
        <time datetime={publishedAt}>{pubDate}</time>
        {modDate && (
          <span class="text-xs text-gray-400">
            (수정: <time datetime={modifiedAt}>{modDate}</time>)
          </span>
        )}
        <span>{readingMinutes}분 읽기</span>
      </div>

      <!-- 커버 이미지 -->
      {coverImage && (
        <img
          src={coverImage}
          alt={coverImageAlt ?? title}
          class="not-prose w-full rounded-xl my-8"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      )}

      <!-- 빠른 답 (AEO/GEO 핵심) -->
      <QuickAnswer summary={quickAnswer} bullets={quickAnswerBullets} />

      <!-- 본문 (MDX/Markdown slot) -->
      <slot />

      <!-- FAQ 섹션 -->
      <FAQSection faqs={faqs} />

      <!-- 다음에 읽을 글 (내부 링크 SEO) -->
      <RelatedPosts posts={relatedPosts} />

      <!-- 저자 바이오 -->
      <AuthorBio
        slug={authorSlug}
        name={authorName}
        bio={authorBio}
        avatarUrl={authorAvatarUrl}
        expertise={authorExpertise}
      />
    </article>

    {/* 글 끝 예약 CTA - 환자 의사결정 전환 (네이버 플레이스 + 전화 + 오시는길) */}
    <aside class="not-prose max-w-[680px] mx-auto mt-12 p-6 md:p-8 rounded-2xl bg-gradient-to-br from-green-50 via-stone-50 to-green-50 ring-1 ring-green-200/60">
      <h2 class="text-xl md:text-2xl font-bold text-stone-900 mb-2">
        {ctaCopy.heading}
      </h2>
      <p class="text-stone-600 leading-relaxed mb-5 text-[15px] md:text-base">
        {ctaCopy.body}
      </p>
      <div class="flex flex-wrap gap-2.5">
        {CLINIC.naverPlaceUrl && (
          <a
            href={CLINIC.naverPlaceUrl}
            target="_blank"
            rel="noopener"
            style="color:#ffffff;background-color:#15803d;"
            class="inline-flex items-center gap-2 px-5 py-3 rounded-full text-[15px] font-bold hover:bg-green-900 shadow-lg shadow-green-900/20"
          >
            네이버 플레이스에서 예약
            <span aria-hidden="true">→</span>
          </a>
        )}
        {CLINIC.phone && (
          <a
            href={`tel:${CLINIC.phone}`}
            class="inline-flex items-center gap-2 px-5 py-3 rounded-full bg-white text-green-900 text-[15px] font-bold border border-green-200 hover:bg-green-50"
          >
            <svg aria-hidden="true" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
            {CLINIC.phone}
          </a>
        )}
        <a
          href="/visit/"
          class="inline-flex items-center gap-2 px-5 py-3 rounded-full bg-white text-stone-700 text-[15px] font-bold border border-stone-300 hover:bg-stone-100"
        >
          <svg aria-hidden="true" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          오시는길
        </a>
      </div>

      {/* 위치·진료시간 요약 - 지역 검색 독자의 핵심 의사결정 정보 ("우리 동네네, 야간진료 하네") */}
      <div class="mt-5 pt-5 border-t border-green-200/60 grid gap-2 sm:grid-cols-2 text-[14px] leading-[1.7] text-stone-700">
        <div>
          <span class="font-bold text-stone-900">위치</span><br />
          대구 달서구 진천로 93 애플플라자 3층<br />
          <span class="text-stone-500">대구도시철도 1호선 진천역 4번 출구 도보 6분 (399m)</span>
        </div>
        <div>
          <span class="font-bold text-stone-900">진료시간</span><br />
          월·수 09:00 - 20:00 (야간진료) · 화·목·금 09:00 - 18:30<br />
          <span class="text-stone-500">토·공휴일 09:00 - 14:00 · 일요일 휴진 · 점심 13:00 - 14:00</span>
        </div>
      </div>
    </aside>

    {/* 출처/인용 (E-E-A-T) - 페이지 최하단 + 기본 접힘: CTA 전환 동선 방해 방지. SEO 신호는 head의 CitationsSchema(JSON-LD)와 DOM 내 텍스트로 유지 */}
    <Citations citations={citations} />

    <!-- 공유 링크 -->
    <div class="max-w-[680px] mx-auto mt-12 pt-6 border-t border-gray-100 flex items-center justify-between text-sm">
      <a href={`/${categorySlug}/`} class="text-deok-600 hover:text-deok-700 font-medium">
        ← {categoryName} 목록으로
      </a>
      <a href="/" class="text-gray-500 hover:text-gray-700">
        홈으로
      </a>
    </div>
  </main>

  <Footer />

  {/* 우측 SNS 사이드바 (데스크톱 전용) - 홈에만 있던 것을 검색 유입 글 페이지에도 노출 */}
  <SocialSidebar />

  {/* 모바일 하단 고정 전화/예약 바 - 검색 유입 모바일 독자 전환 */}
  <MobileCtaBar />
</BaseLayout>
