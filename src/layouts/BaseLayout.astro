---
import { SITE, SITE_VERIFICATIONS } from '~/consts';
import OpenGraph from '~/components/seo/OpenGraph.astro';
import OrganizationSchema from '~/components/seo/OrganizationSchema.astro';
import '~/styles/global.css';

interface Props {
  title: string;
  description?: string;
  type?: 'website' | 'article';
  image?: string;
  publishedAt?: string;
  modifiedAt?: string;
  author?: string;
  noIndex?: boolean;
  canonicalPath?: string; // 루트 기준 상대 경로, 없으면 현재 URL
}

const {
  title,
  description = SITE.description,
  type = 'website',
  image,
  publishedAt,
  modifiedAt,
  author,
  noIndex = false,
  canonicalPath,
} = Astro.props;

const fullTitle = title.includes(SITE.name) ? title : `${title} | ${SITE.name}`;
const currentPath = canonicalPath ?? Astro.url.pathname;
const canonical = `${SITE.url}${currentPath}`;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#1e4a32" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    {!noIndex && <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />}

    <!-- Favicon — logo.png 강제 우선 (브라우저가 SVG를 PNG보다 우선시하는 문제 회피) -->
    <link rel="icon" type="image/png" sizes="any" href="/logo.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/logo.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/logo.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/logo.png" />
    <!-- mask-icon은 Safari pinned tab 전용으로만 SVG 유지 (rel=icon에선 SVG 제거) -->
    <link rel="mask-icon" href="/favicon.svg" color="#0a8a2e" />

    <!-- 웹마스터 도구 소유권 확인 (환경변수에서 주입) -->
    {SITE_VERIFICATIONS.google && (
      <meta name="google-site-verification" content={SITE_VERIFICATIONS.google} />
    )}
    {SITE_VERIFICATIONS.naver && (
      <meta name="naver-site-verification" content={SITE_VERIFICATIONS.naver} />
    )}
    {SITE_VERIFICATIONS.bing && (
      <meta name="msvalidate.01" content={SITE_VERIFICATIONS.bing} />
    )}
    {SITE_VERIFICATIONS.daum && (
      <meta name="daum-site-verification" content={SITE_VERIFICATIONS.daum} />
    )}

    <!-- Open Graph + Twitter -->
    <OpenGraph
      title={title}
      description={description}
      url={currentPath}
      type={type}
      image={image}
      publishedAt={publishedAt}
      modifiedAt={modifiedAt}
      author={author}
    />

    <!-- Sitemap / Feed -->
    <link rel="alternate" type="application/rss+xml" title={`${SITE.name} RSS`} href="/rss.xml" />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    <!-- Preconnect for performance -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />

    <!-- Pretendard Variable (한국어 전용 폰트) -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/variable/pretendardvariable.min.css"
    />

    <!-- Poppins (영문 부제/nameEn 깊이감) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap"
    />

    <!-- Organization + WebSite schema (사이트 전체 공통) -->
    <OrganizationSchema />

    <!-- Vivid Analytics (자체 측정, 봇/본인 IP 자동 제외) -->
    <meta name="vivid-analytics-site" content="taerimclinic" />
    <script async src="https://vivid-blog-proxy.vivid-blog.workers.dev/analytics.js"></script>

    <slot name="head" />
  </head>

  <body>
    <slot />

    <!-- Scroll Reveal — [data-reveal] 요소 자동 활성 (IntersectionObserver) -->
    <script is:inline>
      (() => {
        if (typeof window === 'undefined') return;
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const targets = document.querySelectorAll('[data-reveal]');
        if (!targets.length) return;
        if (reduced || !('IntersectionObserver' in window)) {
          targets.forEach((el) => el.classList.add('is-visible'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.05 }
        );
        targets.forEach((el) => io.observe(el));
      })();
    </script>

    <!-- Header overlay — scroll 12px 이상이면 is-scrolled 토글 -->
    <script is:inline>
      (() => {
        const header = document.querySelector('.v-header-overlay');
        if (!header) return;
        const onScroll = () => {
          if (window.scrollY > 12) header.classList.add('is-scrolled');
          else header.classList.remove('is-scrolled');
        };
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });
      })();
    </script>
  </body>
</html>
