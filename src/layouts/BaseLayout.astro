---
import { SITE, SITE_VERIFICATIONS } from '~/consts';
import OpenGraph from '~/components/seo/OpenGraph.astro';
import OrganizationSchema from '~/components/seo/OrganizationSchema.astro';
import '~/styles/global.css';

interface Props {
  title: string;
  description?: string;
  type?: 'website' | 'article';
  image?: string;
  publishedAt?: string;
  modifiedAt?: string;
  author?: string;
  noIndex?: boolean;
  canonicalPath?: string; // 루트 기준 상대 경로, 없으면 현재 URL
}

const {
  title,
  description = SITE.description,
  type = 'website',
  image,
  publishedAt,
  modifiedAt,
  author,
  noIndex = false,
  canonicalPath,
} = Astro.props;

const fullTitle = title === SITE.name ? title : `${title} | ${SITE.name}`;
const currentPath = canonicalPath ?? Astro.url.pathname;
const canonical = `${SITE.url}${currentPath}`;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#7c3aed" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    {!noIndex && <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- 웹마스터 도구 소유권 확인 (환경변수에서 주입) -->
    {SITE_VERIFICATIONS.google && (
      <meta name="google-site-verification" content={SITE_VERIFICATIONS.google} />
    )}
    {SITE_VERIFICATIONS.naver && (
      <meta name="naver-site-verification" content={SITE_VERIFICATIONS.naver} />
    )}
    {SITE_VERIFICATIONS.bing && (
      <meta name="msvalidate.01" content={SITE_VERIFICATIONS.bing} />
    )}
    {SITE_VERIFICATIONS.daum && (
      <meta name="daum-site-verification" content={SITE_VERIFICATIONS.daum} />
    )}

    <!-- Open Graph + Twitter -->
    <OpenGraph
      title={title}
      description={description}
      url={currentPath}
      type={type}
      image={image}
      publishedAt={publishedAt}
      modifiedAt={modifiedAt}
      author={author}
    />

    <!-- Sitemap / Feed -->
    <link rel="alternate" type="application/rss+xml" title={`${SITE.name} RSS`} href="/rss.xml" />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    <!-- Preconnect for performance -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />

    <!-- Pretendard Variable (한국어 전용 폰트) -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/variable/pretendardvariable.min.css"
    />

    <!-- Organization + WebSite schema (사이트 전체 공통) -->
    <OrganizationSchema />

    <slot name="head" />
  </head>

  <body>
    <slot />
  </body>
</html>
