---
import { getCollection, getEntry } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Header from '~/components/layout/Header.astro';
import Footer from '~/components/layout/Footer.astro';
import RotatingHero from '~/components/home/RotatingHero.astro';
import DirectorProfile from '~/components/home/DirectorProfile.astro';
import ClinicPhilosophy from '~/components/home/ClinicPhilosophy.astro';
import SignatureTreatments from '~/components/home/SignatureTreatments.astro';
import Heritage from '~/components/home/Heritage.astro';
import FeaturedHero from '~/components/home/FeaturedHero.astro';
import CategoryShowcase from '~/components/home/CategoryShowcase.astro';
import SocialSidebar from '~/components/layout/SocialSidebar.astro';
import { SITE, TREATMENTS, CLINIC } from '~/consts';

const categories = (await getCollection('categories')).sort(
  (a, b) => a.data.order - b.data.order
);

const allPosts = (await getCollection('posts', (p) => !p.data.draft)).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);

// 대표 글 - featured + coverImage 우선
const featuredHero: CollectionEntry<'posts'> | undefined =
  allPosts.find((p) => p.data.featured && p.data.coverImage) ??
  allPosts.find((p) => p.data.featured) ??
  allPosts[0];
const featuredId = featuredHero?.id;

// CategoryShowcase용 - featured 글 제외한 카테고리별 분류 (중복 방지)
const postsByCategoryExFeatured: Record<string, CollectionEntry<'posts'>[]> = {};
for (const p of allPosts) {
  if (p.id === featuredId) continue;
  (postsByCategoryExFeatured[p.data.category] ??= []).push(p);
}
const showcaseHasContent = Object.values(postsByCategoryExFeatured).some(arr => arr.length > 0);

// 최신 글 그리드용 - featured + showcase에 쓰인 글 제외
const usedIds = new Set<string>();
if (featuredId) usedIds.add(featuredId);
for (const cat of categories) {
  const posts = postsByCategoryExFeatured[cat.id] ?? [];
  const heroOfCat = posts.find((p) => p.data.featured) ?? posts[0];
  if (heroOfCat) usedIds.add(heroOfCat.id);
  posts.filter((p) => p !== heroOfCat).slice(0, 2).forEach((p) => usedIds.add(p.id));
}
const recentRest = allPosts.filter((p) => !usedIds.has(p.id)).slice(0, 6);
---

<BaseLayout
  title="태림한의원 - 대구 달서구 대천동 한의원 (진천역)"
  description={SITE.description}
  type="website"
  canonicalPath="/"
>
  <Header variant="overlay" />
  <SocialSidebar />

  <main>
    {/* IA: HERO → WHO → WHY → WHAT(증상) → HOW(치료) → WHERE/WHEN → PROOF → ACTION */}

    {/* 1. HERO - 첫인상 + 헤드라인 + 진료시간 */}
    <RotatingHero />

    {/* 2. WHO - 의료진 (서조혁 원장) */}
    <div data-reveal>
      <DirectorProfile />
    </div>

    {/* 3. WHY - 진료 철학 3대 (듣기·체질·과잉진료 X) */}
    <div data-reveal>
      <ClinicPhilosophy />
    </div>

    {/* 4. WHAT - 진료 영역 6축 (환자가 자기 증상으로 진입) */}
    <section id="treatments" class="v-container py-16 md:py-20 scroll-mt-20">
      <header data-reveal class="text-center mb-10">
        <div
          class="inline-block px-3 py-1 rounded-full bg-stone-100 text-stone-700 text-[11px] font-bold tracking-wide mb-3"
          style="font-family: var(--font-display);"
        >
          WHAT · 진료 영역
        </div>
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 tracking-tight">
          어떤 증상으로 오시나요?
        </h2>
        <p class="mt-3 text-sm md:text-base text-gray-600">
          6가지 진료 영역, 한방 통합 케어. 증상이 아닌 원인을 봅니다.
        </p>
      </header>

      <ul class="grid gap-4 md:gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {TREATMENTS.map((t, idx) => (
          <li data-reveal data-reveal-delay={Math.min(idx + 1, 5)}>
            <a
              href={`/${t.slug}/`}
              class="v-card-lift group block h-full rounded-2xl border border-stone-200 bg-white p-6 hover:border-deok-300 hover:shadow-xl hover:shadow-deok-900/10"
            >
              <div class="flex items-center gap-3 mb-3">
                <span class="text-3xl transition-transform duration-500 group-hover:scale-110">{t.icon}</span>
                <h3 class="text-lg font-bold text-gray-900 group-hover:text-deok-800 transition-colors">{t.name}</h3>
              </div>
              <p class="text-sm text-gray-700 leading-relaxed">{t.longDesc}</p>
              <p class="mt-4 text-xs font-semibold text-deok-700 group-hover:text-deok-800 inline-flex items-center gap-1">
                자세히 보기
                <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
              </p>
            </a>
          </li>
        ))}
      </ul>

      {/* 예약 CTA */}
      <div class="mt-12 text-center">
        {CLINIC.naverPlaceUrl ? (
          <a href={CLINIC.naverPlaceUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white font-semibold px-7 py-3.5 rounded-full text-sm md:text-base shadow-lg shadow-green-600/20 hover:shadow-xl transition-all">
            네이버 플레이스에서 진료 예약 →
          </a>
        ) : (
          <a href="/visit/" class="inline-flex items-center gap-2 bg-green-800 hover:bg-green-900 text-white font-semibold px-7 py-3.5 rounded-full text-sm md:text-base shadow-lg transition-all">
            오시는길·진료시간 보기 →
          </a>
        )}
      </div>
    </section>

    {/* 5. HOW - 치료 방법 5종 (어떻게 치료하나요?) */}
    <SignatureTreatments />

    {/* 6. WHERE/WHEN - 한의원 둘러보기 + 연혁 */}
    <div data-reveal>
      <Heritage />
    </div>

    {/* 7. PROOF - 대표 글 (글이 발행되면 표시) */}
    {featuredHero && (
      <div id="quick-answers" class="scroll-mt-20" data-reveal>
        <FeaturedHero post={featuredHero} />
      </div>
    )}

    {/* 8. PROOF - 카테고리별 큐레이션 (featured 제외 후 글 있을 때만) */}
    {showcaseHasContent && (
      <div data-reveal>
        <CategoryShowcase categories={categories} postsByCategory={postsByCategoryExFeatured} />
      </div>
    )}

    {/* 9. PROOF - 최신 글 그리드 (나머지) */}
    {recentRest.length > 0 && (
      <section class="v-container py-12 md:py-16 border-t border-green-100/40">
        <header data-reveal class="flex items-baseline justify-between mb-8">
          <div>
            <h2 class="text-2xl md:text-3xl font-bold text-gray-900">
              더 최신 글
            </h2>
            <p class="mt-1 text-xs text-gray-500">
              홈에 보이지 않는 글은 "전체 글"에서 확인
            </p>
          </div>
          <div class="flex items-center gap-4">
            <a href="/posts/" class="text-sm text-deok-600 hover:text-deok-700 font-bold">
              📚 전체 {allPosts.length}편 →
            </a>
            <a href="/rss.xml" class="text-xs text-gray-400 hover:text-deok-600">
              📡 RSS
            </a>
          </div>
        </header>

        <ul class="grid gap-6 md:grid-cols-3">
          {recentRest.map(async (post, idx) => {
            const category = await getEntry('categories', post.data.category);
            const slug = post.id.replace(/\.mdx?$/, '').split('/').pop();
            return (
              <li data-reveal data-reveal-delay={Math.min(idx + 1, 5)}>
                <a
                  href={`/${post.data.category}/${slug}/`}
                  class="v-card-lift group block h-full rounded-2xl border border-gray-200 bg-white overflow-hidden hover:border-deok-300 hover:shadow-xl hover:shadow-deok-900/10"
                >
                  {post.data.coverImage ? (
                    <div class="aspect-video bg-gray-100 overflow-hidden">
                      <img
                        src={post.data.coverImage}
                        alt={post.data.coverImageAlt ?? post.data.title}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform"
                        loading="lazy"
                        decoding="async"
                      />
                    </div>
                  ) : (
                    <div class="aspect-video bg-gradient-to-br from-green-50 via-green-50 to-green-50 flex items-center justify-center text-4xl">
                      {category?.data.emoji ?? '📝'}
                    </div>
                  )}
                  <div class="p-5">
                    {category && (
                      <span class="inline-block text-xs font-medium text-deok-600 mb-2">
                        {category.data.emoji ?? ''} {category.data.name}
                      </span>
                    )}
                    <h3 class="font-bold text-gray-900 leading-snug group-hover:text-deok-700 transition-colors line-clamp-2">
                      {post.data.title}
                    </h3>
                    <p class="mt-2 text-sm text-gray-600 line-clamp-2 leading-relaxed">
                      {post.data.description}
                    </p>
                    <time class="mt-3 block text-[11px] text-gray-500" datetime={post.data.publishedAt.toISOString()}>
                      {post.data.publishedAt.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </time>
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
      </section>
    )}

    {/* 10. ACTION - 환자 안내 + RSS */}
    <section class="bg-gradient-to-br from-green-50 via-stone-50 to-green-50 py-16 md:py-20 mt-10">
      <div data-reveal class="v-container text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900">
          진료 전 궁금한 점이 있으신가요?
        </h2>
        <p class="mt-3 text-gray-600 max-w-xl mx-auto leading-relaxed">
          한의원 첫 방문이 처음이라면, 진료과목별 가이드를 미리 읽어보시면 진료 시간이 더 충분해집니다.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a href="/posts/" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-green-800 text-white text-sm font-semibold hover:bg-green-900">
            📚 진료 가이드 전체 보기
          </a>
          <a href="/visit/" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-white text-green-900 text-sm font-semibold border border-green-200 hover:bg-green-50">
            🗺️ 오시는길·진료시간
          </a>
          <a href="/rss.xml" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-white text-gray-700 text-sm border border-gray-200 hover:bg-gray-50">
            📡 RSS
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
