---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Header from '~/components/layout/Header.astro';
import Footer from '~/components/layout/Footer.astro';
import Hero from '~/components/home/Hero.astro';
import ClinicHoursStrip from '~/components/home/ClinicHoursStrip.astro';
import DirectorProfile from '~/components/home/DirectorProfile.astro';
import ClinicPhilosophy from '~/components/home/ClinicPhilosophy.astro';
import CareJourney from '~/components/home/CareJourney.astro';
import SignatureTreatments from '~/components/home/SignatureTreatments.astro';
import Heritage from '~/components/home/Heritage.astro';
import ReviewInvite from '~/components/home/ReviewInvite.astro';
import CategoryShowcase from '~/components/home/CategoryShowcase.astro';
import SocialSidebar from '~/components/layout/SocialSidebar.astro';
import { SITE, TREATMENTS, CLINIC } from '~/consts';

const categories = (await getCollection('categories')).sort(
  (a, b) => a.data.order - b.data.order
);

const allPosts = (await getCollection('posts', (p) => !p.data.draft)).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);

// 진료과목별 분류 - 홈 건강정보는 '진료과목별' 단일 섹션으로 통합 (대표글·최신글 그리드 제거)
const postsByCategory: Record<string, CollectionEntry<'posts'>[]> = {};
for (const p of allPosts) {
  (postsByCategory[p.data.category] ??= []).push(p);
}
const showcaseHasContent = Object.values(postsByCategory).some((arr) => arr.length > 0);
---

<BaseLayout
  title="태림한의원 - 대구 달서구 대천동 한의원 (진천역)"
  description={SITE.description}
  type="website"
  canonicalPath="/"
>
  <Header variant="overlay" />
  <SocialSidebar />

  <main>
    {/* IA: HERO → NOW → WHO(원장) → WHY(철학) → CARE(진료과정) → WHAT(증상) → HOW(치료) → 둘러보기 → VOICE(후기) → GUIDE(건강정보) → ACTION
        신뢰·관계 콘텐츠를 앞에 두고, 정보성(블로그)은 후기 다음 보조 블록으로 배치해 "정보만 나열" 인상을 줄임 */}

    {/* 1. HERO - 첫인상 + 헤드라인 */}
    <Hero />

    {/* 1b. NOW - 진료시간 + 위치 + 예약 strip (환자가 "지금 가도 되나" 즉시 판단) */}
    <ClinicHoursStrip />

    {/* 2. WHO - 의료진 (서조혁 원장) */}
    <div data-reveal>
      <DirectorProfile />
    </div>

    {/* 3. WHY - 진료 철학 3대 (듣기·체질·과잉진료 X) */}
    <div data-reveal>
      <ClinicPhilosophy />
    </div>

    {/* 3b. CARE - 진료 과정 4단계 (처음 오시면 어떻게 진료하나, 첫 방문 불안 해소) */}
    <div data-reveal>
      <CareJourney />
    </div>

    {/* 4. WHAT - 진료 영역 6축 (환자가 자기 증상으로 진입) */}
    <section id="treatments" class="v-container py-16 md:py-20 scroll-mt-20">
      <header data-reveal class="text-center mb-10">
        <div
          class="inline-block px-3 py-1 rounded-full bg-stone-100 text-stone-700 text-[11px] font-bold tracking-wide mb-3"
          style="font-family: var(--font-display);"
        >
          WHAT · 진료 영역
        </div>
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 tracking-tight">
          어디가 불편하세요?
        </h2>
        <p class="mt-3 text-sm md:text-base text-gray-600">
          통증, 다이어트, 피부. 결국 환자분 한 사람의 몸이 보내는 이상 신호입니다.
        </p>
      </header>

      <ul class="grid gap-4 md:gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {TREATMENTS.map((t, idx) => (
          <li data-reveal data-reveal-delay={Math.min(idx + 1, 5)}>
            <a
              href={`/${t.slug}/`}
              class="v-card-lift group block h-full rounded-2xl border border-stone-200 bg-white p-6 hover:border-deok-300 hover:shadow-xl hover:shadow-deok-900/10"
            >
              {/* 카테고리 번호 (이모지 대신 미니멀 카드 번호로 전문성 강조) */}
              <div class="flex items-baseline gap-3 mb-3">
                <span
                  class="text-xs font-bold tracking-[0.2em] text-deok-700 tabular-nums"
                  style="font-family: var(--font-display);"
                >
                  {String(idx + 1).padStart(2, '0')}
                </span>
                <span
                  class="text-[10px] font-bold tracking-[0.25em] uppercase text-stone-400"
                  style="font-family: var(--font-display);"
                >
                  {t.nameEn}
                </span>
              </div>
              <h3 class="text-xl md:text-2xl font-bold text-gray-900 group-hover:text-deok-800 transition-colors tracking-tight">{t.name}</h3>
              <p class="mt-3 text-sm text-gray-700 leading-relaxed">{t.longDesc}</p>
              <p class="mt-5 text-xs font-semibold text-deok-700 group-hover:text-deok-800 inline-flex items-center gap-1">
                자세히 보기
                <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
              </p>
            </a>
          </li>
        ))}
      </ul>

      {/* 예약 CTA */}
      <div class="mt-12 text-center">
        {CLINIC.naverPlaceUrl ? (
          <a href={CLINIC.naverPlaceUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white font-semibold px-7 py-3.5 rounded-full text-sm md:text-base shadow-lg shadow-green-600/20 hover:shadow-xl transition-all">
            네이버 플레이스에서 진료 예약 →
          </a>
        ) : (
          <a href="/visit/" class="inline-flex items-center gap-2 bg-green-800 hover:bg-green-900 text-white font-semibold px-7 py-3.5 rounded-full text-sm md:text-base shadow-lg transition-all">
            오시는길·진료시간 보기 →
          </a>
        )}
      </div>
    </section>

    {/* 5. HOW - 치료 방법 5종 (어떻게 치료하나요?) */}
    <SignatureTreatments />

    {/* 6. WHERE/WHEN - 한의원 둘러보기 + 연혁 */}
    <div data-reveal>
      <Heritage />
    </div>

    {/* 7. VOICE - 환자 후기 안내 (의료법 준수: 제3자 플랫폼 유도, 직접 게재 X) */}
    <div data-reveal>
      <ReviewInvite />
    </div>

    {/* 8. GUIDE - 진료과목별 건강 정보 (홈 단일 블록. 대표글·최신글 그리드를 여기로 통합) */}
    {showcaseHasContent && (
      <div id="health-info" class="scroll-mt-20" data-reveal>
        <CategoryShowcase categories={categories} postsByCategory={postsByCategory} />
      </div>
    )}

    {/* 9. ACTION - 환자 안내 (RSS는 사용자 친화 X라 제거, HTML <link rel=alternate>로 검색엔진 노출 유지) */}
    <section class="bg-gradient-to-br from-green-50 via-stone-50 to-green-50 py-16 md:py-20 mt-10">
      <div data-reveal class="v-container text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900">
          진료 전 궁금한 점이 있으신가요?
        </h2>
        <p class="mt-3 text-gray-600 max-w-xl mx-auto leading-relaxed">
          한의원 첫 방문이 처음이라면, 진료과목별 가이드를 미리 읽어보시면 진료 시간이 더 충분해집니다.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a href="/posts/" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-green-800 text-white text-sm font-semibold hover:bg-green-900">
            진료 가이드 전체 보기
            <span aria-hidden="true">→</span>
          </a>
          <a href="/visit/" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-white text-green-900 text-sm font-semibold border border-green-200 hover:bg-green-50">
            <svg aria-hidden="true" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            오시는길·진료시간
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
