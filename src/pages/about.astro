---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Header from '~/components/layout/Header.astro';
import Footer from '~/components/layout/Footer.astro';
import PhilosophyManifesto from '~/components/home/PhilosophyManifesto.astro';
import { SITE, CLINIC, TREATMENTS } from '~/consts';

const title = '원장 소개 - 서조혁 원장';
const description = `${CLINIC.legalName} 서조혁 원장의 인사말과 진료 철학, 진료 영역. 환자 경청, 통증 본질 추적, 과잉진료 X.`;

// 자격·학회 - DirectorProfile와 동일 출처. 검증된 사실만 (학력·면허번호 등 미확인 정보는 넣지 않음).
const credentials = [
  '한의사 면허',
  '대한한의사협회 회원',
  '대한추나의학회 정회원',
  '대한약침학회 정회원',
  '척추신경추나의학회 아카데미 수료',
];
---

<BaseLayout title={title} description={description} type="website" canonicalPath="/about/">
  <Header />

  {/* Hero - 원장 사진 + 이름 + 간단 인용 */}
  <section class="bg-stone-50 border-b border-stone-200">
    <div class="v-container py-12 md:py-20 grid lg:grid-cols-[1fr_1.1fr] gap-10 lg:gap-16 items-center">
      <figure class="relative max-w-md mx-auto lg:mx-0">
        <div class="aspect-[4/5] overflow-hidden rounded-sm shadow-2xl shadow-stone-900/25 ring-1 ring-stone-900/5">
          <img
            src="/images/clinic/photo-edited.jpg"
            alt="서조혁 원장이 진료실에서 환자분의 이야기를 듣는 모습"
            class="w-full h-full object-cover object-center"
            loading="eager"
            decoding="async"
            width="540"
            height="675"
          />
        </div>
      </figure>

      <div>
        <div class="text-[13px] md:text-sm font-bold tracking-[0.2em] uppercase text-green-900 mb-4">
          태림한의원 원장 인사말
        </div>

        {/* 이름 - byline 크기로 절제. 이 페이지의 주인공은 이름이 아니라 핵심 문구 */}
        <h1 class="text-xl md:text-2xl font-bold text-stone-900 tracking-tight">
          서조혁 <span class="text-stone-400 font-medium text-base md:text-lg align-baseline">한의사</span>
        </h1>

        {/* 핵심 문구 - 가장 큰 활자. 이탤릭 뒤 mr로 다음 글자와 간격 확보 */}
        <p class="mt-5 md:mt-6 text-[1.7rem] sm:text-3xl md:text-[2.4rem] font-bold text-stone-900 tracking-tight leading-[1.35]">
          진료실에서 제가 가장 먼저 하는 일은,<br class="hidden sm:block" />
          <span class="font-serif italic text-green-900 mr-1.5">듣는 것</span>입니다.
        </p>
        <div class="mt-5 space-y-4 text-[16px] md:text-[17px] text-stone-700 leading-[1.85]">
          <p>
            어디가, 언제부터, 어떤 하루를 보내다 아프기 시작했는지. 통증을 만든 맥락을 알아야
            그 환자분께 맞는 치료를 설계할 수 있다고 믿습니다.
          </p>
          <p>
            이 세상 모든 병을 100% 낫게 하는 한의사는 없습니다. 다만 환자분의 상태에 맞게
            다각도로 접근해 최선을 다할 뿐입니다. 그래서 진료가 없는 일요일에도 서울로 올라가
            새로운 치료법을 배웁니다.
          </p>
          <p>
            저 역시 아이를 키우는 아버지입니다. 그래서 늘 '내 가족에게도 권할 수 있는 진료인가'를
            먼저 생각합니다. 내 소중한 가족이 안심하고 받을 수 있는 한의원, 그것이 제가 만들어 가려는
            태림한의원입니다.
          </p>
          <p>
            태림(<span class="font-serif text-green-900">太林</span>)은 '큰 숲'이라는 뜻입니다.
            들어오시는 순간부터 나가시는 순간까지, 환자분의 고충을 품어 풀어 드리는 한의원이 되겠습니다.
          </p>
        </div>
        <p class="mt-5 text-sm text-stone-500 tracking-wide">- 태림한의원 원장 서조혁</p>

        {/* 자격·학회 - 도감식 spec 표 대신 검증된 자격만 chip으로 */}
        <div class="mt-8 border-t border-stone-200 pt-7">
          <div
            class="text-[11px] font-bold tracking-[0.25em] uppercase text-green-900 mb-4"
            style="font-family: var(--font-display);"
          >
            자격 · 학회
          </div>
          <ul class="flex flex-wrap gap-2.5">
            {credentials.map((c) => (
              <li class="px-3.5 py-1.5 rounded-full bg-green-50 text-green-900 text-[14px] md:text-[15px] font-medium ring-1 ring-green-100">
                {c}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  {/* 진료 철학 매니페스토 - 좌우 교차 + scroll reveal (emptyfill 패턴) */}
  <PhilosophyManifesto />

  {/* 진료 영역 + 콘텐츠 정책 - 압축된 정보 영역 */}
  <section class="bg-stone-50 border-t border-stone-100 py-16 md:py-24">
    <div class="v-container max-w-4xl">
      {/* 진료 영역 */}
      <div class="mb-16 md:mb-20">
        <div class="text-[13px] md:text-sm font-bold tracking-[0.25em] uppercase text-green-900 mb-5">
          진료 영역
        </div>
        <h2 class="text-3xl md:text-4xl font-bold text-stone-900 tracking-tight leading-[1.2]">
          6가지 진료 영역, <span class="font-serif italic text-green-900 mr-2">한방 통합</span>으로
        </h2>

        <ul class="mt-10 md:mt-12 grid sm:grid-cols-2 gap-x-10 gap-y-6">
          {TREATMENTS.map((t, idx) => (
            <li class="border-b border-stone-200 pb-5">
              <div class="flex items-baseline gap-3 mb-2">
                <span
                  class="text-xs font-bold tracking-[0.2em] text-deok-700 tabular-nums"
                  style="font-family: var(--font-display);"
                >
                  {String(idx + 1).padStart(2, '0')}
                </span>
                <h3 class="text-xl md:text-2xl font-bold text-stone-900 tracking-tight">{t.name}</h3>
              </div>
              <p class="text-[16px] md:text-[17px] text-stone-700 leading-[1.7]">{t.shortDesc}</p>
            </li>
          ))}
        </ul>

        <div class="mt-10 text-center md:text-left">
          <a href="/visit/" style="color:#ffffff;background-color:#15803d;" class="inline-flex items-center gap-2 px-7 py-4 text-[17px] md:text-lg font-bold hover:bg-green-900 shadow-lg shadow-green-950/15 transition-all">
            오시는길·진료시간 보기 →
          </a>
        </div>
      </div>

      {/* 콘텐츠 정책 - 작게, 의료법 신뢰 */}
      <details class="mt-16 border-t border-stone-200 pt-10 group">
        <summary class="cursor-pointer text-[15px] md:text-base font-bold text-stone-700 hover:text-green-900 list-none flex items-center gap-2">
          <span aria-hidden="true" class="text-green-800 transition-transform group-open:rotate-90">▸</span>
          이 사이트의 콘텐츠 정책 - 의료법 광고 가이드라인
        </summary>
        <div class="mt-5 text-[15px] md:text-base text-stone-600 leading-[1.85] space-y-3 pl-6">
          <p>태림한의원 사이트의 모든 진료 가이드 글은 다음을 따릅니다.</p>
          <ul class="space-y-2 list-disc pl-5">
            <li>대한한의사협회·한국한의학연구원·식약처 등 공신력 있는 출처를 우선 인용합니다.</li>
            <li>"완치", "100%", "부작용 없음" 같은 단정적 표현을 사용하지 않습니다. 치료 효과는 개인차가 있습니다.</li>
            <li>환자 사례는 환자분의 동의를 받은 경우에 한해 일반화 없이 인용합니다. 개별 경과는 다를 수 있습니다.</li>
            <li>사이트의 정보는 일반적인 안내이며, 진단·처방은 반드시 진료를 통해 이뤄집니다.</li>
            <li>의료법 광고 사전심의 대상임을 인지하고, 비교 우위·치료 보장·과장 표현을 회피합니다.</li>
          </ul>
        </div>
      </details>
    </div>
  </section>

  <Footer />
</BaseLayout>
