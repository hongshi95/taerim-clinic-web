---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { SITE, SITE_VERIFICATIONS } from '~/consts';

interface WebmasterSite {
  id: 'google' | 'naver' | 'bing' | 'daum';
  label: string;
  flag: string;
  marketShare: string;
  url: string;
  verifyKey: string;
  envVar: string;
  steps: string[];
  currentValue: string;
}

const sites: WebmasterSite[] = [
  {
    id: 'google',
    label: 'Google Search Console',
    flag: '🌍',
    marketShare: '전 세계 90% · 한국 30%',
    url: 'https://search.google.com/search-console',
    verifyKey: 'google-site-verification',
    envVar: 'PUBLIC_GSC_VERIFICATION',
    steps: [
      '위 URL 접속 → "속성 추가" → "URL 접두어" 선택',
      'https://deokgye.com 입력',
      '"HTML 태그" 소유권 확인 방법 선택',
      'content="..." 값 복사',
      'Secrets Manager(바탕화면) → PUBLIC_GSC_VERIFICATION 붙여넣기',
      '저장 후 git push → 배포 완료 → "확인" 클릭',
      'sitemap: https://deokgye.com/sitemap-index.xml 제출',
    ],
    currentValue: SITE_VERIFICATIONS.google,
  },
  {
    id: 'naver',
    label: 'Naver Search Advisor',
    flag: '🇰🇷',
    marketShare: '한국 56% (가장 중요)',
    url: 'https://searchadvisor.naver.com',
    verifyKey: 'naver-site-verification',
    envVar: 'PUBLIC_NAVER_VERIFICATION',
    steps: [
      '위 URL 접속 → 네이버 로그인',
      '"웹마스터 도구" → "사이트 등록"',
      'https://deokgye.com 입력',
      '"HTML 태그" 선택 → content="..." 값 복사',
      'Secrets Manager → PUBLIC_NAVER_VERIFICATION 붙여넣기',
      '저장 후 git push → 배포 완료 → "소유 확인"',
      'sitemap 제출 + RSS 제출 (rss.xml)',
    ],
    currentValue: SITE_VERIFICATIONS.naver,
  },
  {
    id: 'bing',
    label: 'Bing Webmaster Tools',
    flag: '🅱️',
    marketShare: 'Bing + Yahoo + DuckDuckGo',
    url: 'https://www.bing.com/webmasters',
    verifyKey: 'msvalidate.01',
    envVar: 'PUBLIC_BING_VERIFICATION',
    steps: [
      '위 URL 접속 → Microsoft 계정 로그인',
      '"사이트 추가" → https://deokgye.com',
      '💡 "Import from GSC" 선택하면 Google Search Console 설정 자동 복사',
      '수동 등록 시: "HTML 메타 태그" 선택 → content="..." 복사',
      'Secrets Manager → PUBLIC_BING_VERIFICATION 붙여넣기',
      '저장 후 git push → 배포 완료 → "확인"',
    ],
    currentValue: SITE_VERIFICATIONS.bing,
  },
  {
    id: 'daum',
    label: 'Daum 검색등록',
    flag: '🟡',
    marketShare: '한국 4%',
    url: 'https://register.search.daum.net',
    verifyKey: 'daum-site-verification',
    envVar: 'PUBLIC_DAUM_VERIFICATION',
    steps: [
      '위 URL 접속 → Daum/Kakao 계정 로그인',
      '"사이트 검색등록" → https://deokgye.com',
      '(Daum은 별도 웹마스터 도구 없음 - 단순 사이트 등록)',
      'verification code 받으면 → Secrets Manager → PUBLIC_DAUM_VERIFICATION',
    ],
    currentValue: SITE_VERIFICATIONS.daum,
  },
];

const totalRegistered = sites.filter((s) => s.currentValue).length;
---

<BaseLayout title="웹마스터 도구" noIndex={true}>
  <div class="min-h-screen bg-gray-50">
    <header class="bg-white border-b border-gray-200 sticky top-0 z-10">
      <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <a href="/admin/dashboard/" class="text-lg font-bold text-deok-700">{SITE.name}</a>
          <span class="text-xs px-2 py-0.5 rounded bg-teal-100 text-teal-800 font-medium">WEBMASTER</span>
        </div>
        <nav class="flex items-center gap-4 text-sm">
          <a href="/admin/dashboard/" class="text-gray-500 hover:text-deok-700">← 대시보드</a>
        </nav>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-6 py-8">
      <header class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">🌐 웹마스터 도구 등록</h1>
        <p class="text-gray-600">
          한국 시장 완전 커버: <strong>{totalRegistered}/4 등록 완료</strong> · 4종 모두 등록하면 시장 91% 커버 (네이버 56 + 구글 30 + 다음 4 + Bing 1)
        </p>
      </header>

      <!-- 전체 상태 -->
      <div class="grid gap-4 md:grid-cols-4 mb-8">
        {sites.map((s) => (
          <div class={`p-4 rounded-xl border ${s.currentValue ? 'bg-green-50 border-green-200' : 'bg-white border-gray-200'}`}>
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xl">{s.flag}</span>
              <span class="text-sm font-semibold text-gray-900">{s.id.toUpperCase()}</span>
            </div>
            <p class="text-xs text-gray-500 mb-2">{s.marketShare}</p>
            {s.currentValue ? (
              <span class="text-xs font-medium text-green-700">✅ 등록 완료</span>
            ) : (
              <span class="text-xs font-medium text-amber-700">⏳ 대기 중</span>
            )}
          </div>
        ))}
      </div>

      <!-- 각 사이트 상세 -->
      <div class="space-y-6">
        {sites.map((s) => (
          <section class={`bg-white rounded-xl border ${s.currentValue ? 'border-green-200' : 'border-gray-200'} overflow-hidden`}>
            <div class="p-5 border-b border-gray-100 flex items-center justify-between gap-4">
              <div class="flex items-center gap-3">
                <span class="text-2xl">{s.flag}</span>
                <div>
                  <h2 class="text-lg font-bold text-gray-900">{s.label}</h2>
                  <p class="text-xs text-gray-500">{s.marketShare}</p>
                </div>
              </div>
              <a
                href={s.url}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-1.5 px-4 py-2 bg-deok-600 text-white rounded-lg text-sm font-medium hover:bg-deok-700"
              >
                등록 페이지 열기 ↗
              </a>
            </div>

            <div class="p-5">
              <!-- 상태 -->
              <div class="mb-4 flex items-center gap-2 text-sm">
                <span class="text-gray-500">환경변수:</span>
                <code class="px-2 py-0.5 rounded bg-gray-100 text-xs">{s.envVar}</code>
                {s.currentValue ? (
                  <span class="text-green-700">✅ 설정됨</span>
                ) : (
                  <span class="text-amber-700">❌ 미설정</span>
                )}
              </div>

              <!-- 단계 -->
              <div class="p-4 bg-gray-50 rounded-lg">
                <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">등록 단계</h3>
                <ol class="space-y-1.5 text-sm text-gray-700 list-decimal pl-5">
                  {s.steps.map((step) => (
                    <li>{step}</li>
                  ))}
                </ol>
              </div>
            </div>
          </section>
        ))}
      </div>

      <!-- 안내 -->
      <section class="mt-10 p-6 bg-teal-50 rounded-xl border border-teal-100">
        <h3 class="font-bold text-teal-900 mb-3">💡 verification 코드 관리</h3>
        <ol class="text-sm text-gray-700 space-y-2 list-decimal pl-5">
          <li>각 웹마스터 도구에서 메타태그 소유권 확인 → <code class="px-1.5 py-0.5 rounded bg-white">content="..."</code> 값 복사</li>
          <li>바탕화면 <strong>Secrets Manager</strong> 더블클릭 → 해당 환경변수에 붙여넣기 → 저장</li>
          <li><code class="px-1.5 py-0.5 rounded bg-white">git push</code> 트리거 → pre-push 훅이 자동 배포</li>
          <li>배포 완료(1~2분) 후 각 웹마스터 도구에서 "확인" 클릭 → 등록 완료</li>
          <li>sitemap 제출: <code class="px-1.5 py-0.5 rounded bg-white">https://deokgye.com/sitemap-index.xml</code></li>
        </ol>
      </section>
    </main>
  </div>

  <script is:inline>
    fetch('/api/admin-check').then((r) => {
      if (!r.ok) window.location.href = '/admin/';
    });
  </script>
</BaseLayout>
