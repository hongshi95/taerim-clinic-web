---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { SITE } from '~/consts';
import fs from 'node:fs';
import path from 'node:path';

// 빌드 시점에 주요 문서 읽기
const root = path.resolve(process.cwd());
function readSafe(p: string): string {
  try {
    return fs.readFileSync(path.join(root, p), 'utf-8');
  } catch {
    return '';
  }
}

const docs = [
  {
    id: 'spec',
    label: 'SPEC.md — 프로젝트 사양서',
    icon: '📋',
    content: readSafe('SPEC.md'),
  },
  {
    id: 'webmaster',
    label: 'WEBMASTER-SETUP.md — 웹마스터 등록',
    icon: '🌐',
    content: readSafe('WEBMASTER-SETUP.md'),
  },
  {
    id: 'readme',
    label: 'README.md',
    icon: '📖',
    content: readSafe('README.md'),
  },
].filter((d) => d.content);
---

<BaseLayout title="프로젝트 문서" noIndex={true}>
  <div class="min-h-screen bg-gray-50">
    <header class="bg-white border-b border-gray-200 sticky top-0 z-10">
      <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <a href="/admin/dashboard/" class="text-lg font-bold text-deok-700">{SITE.name}</a>
          <span class="text-xs px-2 py-0.5 rounded bg-gray-100 text-gray-800 font-medium">DOCS</span>
        </div>
        <nav class="flex items-center gap-4 text-sm">
          <a href="/admin/dashboard/" class="text-gray-500 hover:text-deok-700">← 대시보드</a>
        </nav>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-6 py-8">
      <header class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">📚 프로젝트 문서</h1>
        <p class="text-gray-600">SPEC·웹마스터·README 원문 미러 (빌드 시점 스냅샷). 수정: 루트 .md 편집 → git push.</p>
      </header>

      <div class="grid gap-6 lg:grid-cols-[240px_1fr]">
        <!-- 목차 -->
        <aside class="lg:sticky lg:top-20 h-fit">
          <nav class="p-4 bg-white rounded-xl border border-gray-200">
            <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">목차</h2>
            <ul class="space-y-1">
              {docs.map((d) => (
                <li>
                  <a href={`#${d.id}`} class="flex items-center gap-2 text-sm text-gray-700 hover:text-deok-700 py-1.5 px-2 rounded hover:bg-gray-50">
                    <span>{d.icon}</span>
                    <span class="truncate">{d.label.split(' — ')[0]}</span>
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>

        <!-- 본문 -->
        <div class="space-y-8 min-w-0">
          {docs.length === 0 ? (
            <p class="p-8 text-center text-gray-500">문서 파일 없음</p>
          ) : (
            docs.map((d) => (
              <section id={d.id} class="scroll-mt-20 bg-white rounded-xl border border-gray-200 overflow-hidden">
                <header class="p-5 bg-gradient-to-r from-gray-50 to-transparent border-b border-gray-100">
                  <h2 class="text-lg font-bold text-gray-900 flex items-center gap-2">
                    <span>{d.icon}</span>
                    <span>{d.label}</span>
                  </h2>
                  <p class="text-xs text-gray-500 mt-1">{d.content.length.toLocaleString()} 자</p>
                </header>
                <pre class="p-5 text-xs font-mono text-gray-800 whitespace-pre-wrap break-words overflow-x-auto leading-relaxed">{d.content}</pre>
              </section>
            ))
          )}
        </div>
      </div>
    </main>
  </div>

  <script is:inline>
    fetch('/api/admin-check').then((r) => {
      if (!r.ok) window.location.href = '/admin/';
    });
  </script>
</BaseLayout>
