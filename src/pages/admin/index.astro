---
import BaseLayout from '~/layouts/BaseLayout.astro';
---

<BaseLayout title="관리자 로그인" noIndex={true}>
  <main class="min-h-screen flex items-center justify-center p-6 bg-gray-50">
    <div class="w-full max-w-sm bg-white rounded-2xl border border-gray-200 p-8 shadow-sm">
      <h1 class="text-2xl font-bold text-gray-900 mb-2">덕계 관리자</h1>
      <p class="text-sm text-gray-600 mb-6">PIN을 입력하세요.</p>

      <form id="login-form" class="space-y-4">
        <div>
          <label for="pin" class="block text-sm font-medium text-gray-700 mb-1.5">
            PIN
          </label>
          <input
            type="password"
            id="pin"
            name="pin"
            required
            autocomplete="current-password"
            class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-deok-500 focus:border-deok-500 outline-none"
            placeholder="4~20자리"
          />
        </div>
        <button
          type="submit"
          class="w-full py-2.5 rounded-lg bg-deok-600 text-white font-medium hover:bg-deok-700 transition-colors disabled:opacity-50"
          id="submit-btn"
        >
          로그인
        </button>
        <p id="error-msg" class="text-sm text-red-600 hidden"></p>
      </form>
    </div>
  </main>

  <script is:inline>
    const form = document.getElementById('login-form');
    const btn = document.getElementById('submit-btn');
    const errMsg = document.getElementById('error-msg');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      errMsg.classList.add('hidden');
      btn.disabled = true;
      btn.textContent = '확인 중...';

      const pin = document.getElementById('pin').value;

      try {
        const res = await fetch('/api/auth', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ pin }),
        });

        if (res.ok) {
          window.location.href = '/admin/dashboard/';
        } else {
          const data = await res.json().catch(() => ({}));
          errMsg.textContent = data.error || '로그인 실패';
          errMsg.classList.remove('hidden');
        }
      } catch (err) {
        errMsg.textContent = '네트워크 오류: ' + String(err);
        errMsg.classList.remove('hidden');
      } finally {
        btn.disabled = false;
        btn.textContent = '로그인';
      }
    });

    // 이미 로그인된 상태면 대시보드로
    fetch('/api/admin-check').then((r) => {
      if (r.ok) window.location.href = '/admin/dashboard/';
    });
  </script>
</BaseLayout>
