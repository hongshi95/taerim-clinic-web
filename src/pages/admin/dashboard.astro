---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { SITE } from '~/consts';
---

<BaseLayout title="대시보드" noIndex={true}>
  <div class="min-h-screen bg-gray-50">
    <!-- Top bar -->
    <header class="bg-white border-b border-gray-200 sticky top-0 z-10">
      <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <a href="/" class="text-lg font-bold text-deok-700">{SITE.name}</a>
          <span class="text-xs px-2 py-0.5 rounded bg-deok-100 text-deok-700 font-medium">ADMIN</span>
        </div>
        <nav class="flex items-center gap-4 text-sm">
          <a href="/admin/dashboard/" class="text-gray-700 hover:text-deok-700 font-medium">대시보드</a>
          <a href="https://deokgye.com" target="_blank" class="text-gray-500 hover:text-deok-700">사이트 보기 ↗</a>
          <button id="logout-btn" class="text-gray-500 hover:text-red-600">로그아웃</button>
        </nav>
      </div>
    </header>

    <!-- Main -->
    <main class="max-w-6xl mx-auto px-6 py-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-2">관리 대시보드</h1>
      <p class="text-gray-600 mb-8">사이트 현황 + D1에 저장된 글 관리.</p>

      <!-- 통계 카드 -->
      <div id="stats" class="grid gap-4 md:grid-cols-4 mb-10">
        <div class="p-5 bg-white rounded-xl border border-gray-200">
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Published</p>
          <p class="text-2xl font-bold text-gray-900 mt-1" id="stat-published">—</p>
        </div>
        <div class="p-5 bg-white rounded-xl border border-gray-200">
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Draft</p>
          <p class="text-2xl font-bold text-gray-900 mt-1" id="stat-draft">—</p>
        </div>
        <div class="p-5 bg-white rounded-xl border border-gray-200">
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">카테고리</p>
          <p class="text-2xl font-bold text-gray-900 mt-1">3</p>
        </div>
        <div class="p-5 bg-white rounded-xl border border-gray-200">
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">MDX 글</p>
          <p class="text-2xl font-bold text-gray-900 mt-1">10</p>
          <p class="text-xs text-gray-500 mt-1">Content Collections</p>
        </div>
      </div>

      <!-- 관리 도구 -->
      <section class="mb-10">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">🛠️ 관리 도구</h2>
        <div class="grid gap-3 md:grid-cols-3">
          <a href="/admin/metrics/"
             class="p-4 bg-gradient-to-br from-blue-50 to-white rounded-xl border border-blue-200 hover:border-blue-400 hover:shadow-md transition-all">
            <div class="text-sm font-medium text-blue-900">📊 운영 지표</div>
            <div class="text-xs text-blue-700 mt-1">D1 실시간 통계 · 갱신 대기 · 발행 추이</div>
          </a>
          <a href="/admin/architecture/"
             class="p-4 bg-gradient-to-br from-indigo-50 to-white rounded-xl border border-indigo-200 hover:border-indigo-400 hover:shadow-md transition-all">
            <div class="text-sm font-medium text-indigo-900">⚡ 시스템 아키텍처</div>
            <div class="text-xs text-indigo-700 mt-1">컴포넌트 · 데이터 흐름 · 트리거 체계</div>
          </a>
          <a href="/admin/audit-log/"
             class="p-4 bg-gradient-to-br from-amber-50 to-white rounded-xl border border-amber-200 hover:border-amber-400 hover:shadow-md transition-all">
            <div class="text-sm font-medium text-amber-900">📜 활동 이력</div>
            <div class="text-xs text-amber-700 mt-1">생성 · 수정 · 발행 · 리뷰 타임라인</div>
          </a>
          <a href="/admin/rules/"
             class="p-4 bg-gradient-to-br from-purple-50 to-white rounded-xl border border-purple-200 hover:border-purple-400 hover:shadow-md transition-all">
            <div class="text-sm font-medium text-purple-900">📋 운영 규칙</div>
            <div class="text-xs text-purple-700 mt-1">SEO/AEO/GEO/네이버/포맷/검증 19 카테고리</div>
          </a>
          <a href="/admin/webmaster/"
             class="p-4 bg-gradient-to-br from-teal-50 to-white rounded-xl border border-teal-200 hover:border-teal-400 hover:shadow-md transition-all">
            <div class="text-sm font-medium text-teal-900">🌐 웹마스터 4종</div>
            <div class="text-xs text-teal-700 mt-1">Google · Naver · Bing · Daum 등록</div>
          </a>
          <a href="/admin/docs/"
             class="p-4 bg-gradient-to-br from-slate-50 to-white rounded-xl border border-slate-200 hover:border-slate-400 hover:shadow-md transition-all">
            <div class="text-sm font-medium text-slate-900">📚 프로젝트 문서</div>
            <div class="text-xs text-slate-700 mt-1">SPEC · 웹마스터 · README 원문</div>
          </a>
        </div>
      </section>

      <!-- 외부 콘솔 -->
      <section class="mb-10">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">🔗 외부 콘솔</h2>
        <div class="grid gap-3 md:grid-cols-3">
          <a href="https://dash.cloudflare.com/5f4cebf657294ccc0a8548777f19a0d9/pages/view/deokgye-web"
             target="_blank"
             class="p-4 bg-white rounded-xl border border-gray-200 hover:border-deok-300 hover:shadow-md transition-all">
            <div class="text-sm font-medium text-gray-900">Cloudflare Pages ↗</div>
            <div class="text-xs text-gray-500 mt-1">배포 로그 + 환경변수</div>
          </a>
          <a href="https://dash.cloudflare.com/5f4cebf657294ccc0a8548777f19a0d9/workers/d1/databases/bbb746fa-6343-4be0-8f2c-5b33f0862794"
             target="_blank"
             class="p-4 bg-white rounded-xl border border-gray-200 hover:border-deok-300 hover:shadow-md transition-all">
            <div class="text-sm font-medium text-gray-900">D1 데이터베이스 ↗</div>
            <div class="text-xs text-gray-500 mt-1">쿼리 + 마이그레이션</div>
          </a>
          <a href="https://search.google.com/search-console"
             target="_blank"
             class="p-4 bg-white rounded-xl border border-gray-200 hover:border-deok-300 hover:shadow-md transition-all">
            <div class="text-sm font-medium text-gray-900">Google Search Console</div>
            <div class="text-xs text-gray-500 mt-1">인덱싱 상태</div>
          </a>
        </div>
      </section>

      <!-- D1 글 목록 -->
      <section>
        <div class="flex items-baseline justify-between mb-4">
          <h2 class="text-lg font-semibold text-gray-900">D1 글 목록</h2>
          <span class="text-xs text-gray-500">/api/posts 에서 조회</span>
        </div>

        <div id="posts-container" class="bg-white rounded-xl border border-gray-200 overflow-hidden">
          <div class="p-8 text-center text-gray-500">로딩 중...</div>
        </div>
      </section>

      <!-- 발행 가이드 -->
      <section class="mt-10 p-6 bg-deok-50 rounded-xl border border-deok-100">
        <h3 class="font-bold text-deok-900 mb-3">💡 글 발행 방법</h3>
        <ol class="text-sm text-gray-700 space-y-2 list-decimal pl-5">
          <li><strong>MDX 방식</strong>: <code class="px-1.5 py-0.5 rounded bg-white">src/content/posts/</code> 에 <code class="px-1.5 py-0.5 rounded bg-white">.mdx</code> 파일 추가 → git push → 자동 배포</li>
          <li><strong>API 방식</strong>: <code class="px-1.5 py-0.5 rounded bg-white">POST /api/publish</code> (Bearer PUBLISH_TOKEN 필요)</li>
          <li><strong>vivid-blog 연동</strong>: Gemini로 생성 → 자동 압축 → /api/publish 호출</li>
        </ol>
      </section>
    </main>
  </div>

  <script is:inline>
    // 인증 체크
    fetch('/api/admin-check').then((r) => {
      if (!r.ok) window.location.href = '/admin/';
    });

    // 로그아웃
    document.getElementById('logout-btn')?.addEventListener('click', async () => {
      await fetch('/api/auth', { method: 'DELETE' });
      window.location.href = '/admin/';
    });

    // 글 목록 로드
    async function loadPosts() {
      try {
        const resAll = await fetch('/api/posts?status=published&limit=100');
        const resDrafts = await fetch('/api/posts?status=draft&limit=100');
        const [pubData, draftData] = await Promise.all([resAll.json(), resDrafts.json()]);

        const pub = pubData.posts || [];
        const drafts = draftData.posts || [];

        document.getElementById('stat-published').textContent = String(pub.length);
        document.getElementById('stat-draft').textContent = String(drafts.length);

        const allPosts = [...pub, ...drafts];
        const container = document.getElementById('posts-container');

        if (allPosts.length === 0) {
          container.innerHTML = `
            <div class="p-8 text-center">
              <p class="text-gray-500 mb-2">D1에 저장된 글이 없습니다.</p>
              <p class="text-xs text-gray-400">현재 보이는 10개 글은 MDX 파일 (Content Collections)입니다.</p>
              <p class="text-xs text-gray-400 mt-2">vivid-blog이 /api/publish 호출하면 여기 표시됩니다.</p>
            </div>
          `;
          return;
        }

        container.innerHTML = `
          <table class="w-full text-sm">
            <thead class="bg-gray-50 text-xs uppercase tracking-wider text-gray-500">
              <tr>
                <th class="px-4 py-3 text-left">제목</th>
                <th class="px-4 py-3 text-left">카테고리</th>
                <th class="px-4 py-3 text-left">상태</th>
                <th class="px-4 py-3 text-left">팩트체크</th>
                <th class="px-4 py-3 text-left">발행일</th>
                <th class="px-4 py-3 text-right">액션</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              ${allPosts.map((p) => `
                <tr>
                  <td class="px-4 py-3">
                    <div class="font-medium text-gray-900">${escapeHtml(p.title)}</div>
                    <div class="text-xs text-gray-500 mt-0.5">${escapeHtml(p.slug)}</div>
                  </td>
                  <td class="px-4 py-3">${escapeHtml(p.category_name || '-')}</td>
                  <td class="px-4 py-3">
                    <span class="text-xs px-2 py-1 rounded ${
                      p.status === 'published' ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-700'
                    }">
                      ${p.status}
                    </span>
                  </td>
                  <td class="px-4 py-3">
                    ${factCheckBadge(p)}
                  </td>
                  <td class="px-4 py-3 text-gray-500 text-xs">
                    ${p.published_at ? new Date(p.published_at).toLocaleDateString('ko-KR') : '—'}
                  </td>
                  <td class="px-4 py-3 text-right space-x-2">
                    ${p.fact_check_status && p.fact_check_status !== 'auto-approved' ? `
                      <a href="/admin/review/?slug=${encodeURIComponent(p.slug)}" class="text-amber-600 hover:text-amber-700 text-xs font-medium">
                        리뷰
                      </a>
                    ` : ''}
                    ${p.status === 'published' ? `
                      <a href="/${p.category_slug}/${p.slug}/" target="_blank" class="text-deok-600 hover:text-deok-700 text-xs font-medium">
                        보기 ↗
                      </a>
                    ` : ''}
                  </td>
                </tr>
              `).join('')}
            </tbody>
          </table>
        `;
      } catch (err) {
        document.getElementById('posts-container').innerHTML = `
          <div class="p-8 text-center text-red-600">
            글 로딩 실패: ${escapeHtml(String(err))}
          </div>
        `;
      }
    }

    function escapeHtml(s) {
      return String(s).replace(/[&<>"']/g, (c) =>
        ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c])
      );
    }

    function factCheckBadge(p) {
      const s = p.fact_check_status;
      const c = p.fact_check_confidence;
      if (!s || s === 'pending') {
        return '<span class="text-xs text-gray-400">—</span>';
      }
      const conf = c ? ` (${c})` : '';
      if (s === 'auto-approved') {
        return `<span class="text-xs px-2 py-1 rounded bg-green-100 text-green-800" title="${escapeHtml(p.fact_check_summary || '')}">✅ 자동승인${escapeHtml(conf)}</span>`;
      }
      if (s === 'needs-review') {
        return `<span class="text-xs px-2 py-1 rounded bg-amber-100 text-amber-800" title="${escapeHtml(p.fact_check_summary || '')}">⚠️ 리뷰필요${escapeHtml(conf)}</span>`;
      }
      if (s === 'blocked') {
        return `<span class="text-xs px-2 py-1 rounded bg-red-100 text-red-800" title="${escapeHtml(p.fact_check_summary || '')}">❌ 차단${escapeHtml(conf)}</span>`;
      }
      if (s === 'reviewed') {
        return `<span class="text-xs px-2 py-1 rounded bg-blue-100 text-blue-800">✓ 리뷰완료</span>`;
      }
      return `<span class="text-xs text-gray-500">${escapeHtml(s)}</span>`;
    }

    loadPosts();
  </script>
</BaseLayout>
