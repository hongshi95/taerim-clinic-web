---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { SITE } from '~/consts';
---

<BaseLayout title="활동 이력" noIndex={true}>
  <div class="min-h-screen bg-gray-50">
    <header class="bg-white border-b border-gray-200 sticky top-0 z-10">
      <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <a href="/admin/dashboard/" class="text-lg font-bold text-deok-700">{SITE.name}</a>
          <span class="text-xs px-2 py-0.5 rounded bg-amber-100 text-amber-800 font-medium">AUDIT LOG</span>
        </div>
        <nav class="flex items-center gap-4 text-sm">
          <a href="/admin/dashboard/" class="text-gray-500 hover:text-deok-700">← 대시보드</a>
        </nav>
      </div>
    </header>

    <main class="max-w-5xl mx-auto px-6 py-8">
      <header class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">📜 활동 이력</h1>
        <p class="text-gray-600">최근 50개 이벤트 — 생성 · 수정 · 발행 · 리뷰</p>
      </header>

      <div id="loading" class="p-8 text-center text-gray-500">로딩 중...</div>
      <div id="error" class="hidden p-6 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm"></div>
      <div id="timeline" class="hidden"></div>
    </main>
  </div>

  <script is:inline>
    fetch('/api/admin-check').then((r) => {
      if (!r.ok) window.location.href = '/admin/';
    });

    function escapeHtml(s) {
      return String(s ?? '').replace(/[&<>"']/g, (c) =>
        ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c])
      );
    }

    function formatTime(iso) {
      const d = new Date(iso);
      const now = new Date();
      const diffMin = Math.floor((now - d) / 60000);
      if (diffMin < 1) return '방금 전';
      if (diffMin < 60) return `${diffMin}분 전`;
      if (diffMin < 1440) return `${Math.floor(diffMin / 60)}시간 전`;
      return d.toLocaleDateString('ko-KR', { year: '2-digit', month: '2-digit', day: '2-digit' });
    }

    const TYPE_META = {
      created: { icon: '✨', label: '생성', color: 'text-blue-700 bg-blue-50' },
      modified: { icon: '✏️', label: '수정', color: 'text-amber-700 bg-amber-50' },
      published: { icon: '🚀', label: '발행', color: 'text-green-700 bg-green-50' },
      reviewed: { icon: '✓', label: '리뷰', color: 'text-purple-700 bg-purple-50' },
    };

    async function load() {
      try {
        const res = await fetch('/api/audit-log?limit=100');
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'load failed');

        document.getElementById('loading').classList.add('hidden');
        const tl = document.getElementById('timeline');
        tl.classList.remove('hidden');

        if (!data.events || data.events.length === 0) {
          tl.innerHTML = '<p class="p-8 text-center text-gray-500">활동 이력 없음</p>';
          return;
        }

        // 날짜별 그룹핑
        const byDay = {};
        for (const e of data.events) {
          const day = e.timestamp.slice(0, 10);
          (byDay[day] = byDay[day] || []).push(e);
        }

        tl.innerHTML = Object.entries(byDay).map(([day, events]) => `
          <section class="mb-8">
            <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3 sticky top-14 bg-gray-50 py-2 z-0">
              ${day} (${events.length}건)
            </h2>
            <ol class="relative border-l-2 border-gray-200 ml-3 space-y-4">
              ${events.map((e) => {
                const meta = TYPE_META[e.type] || { icon: '•', label: e.type, color: 'bg-gray-100' };
                return `
                  <li class="ml-6 relative">
                    <span class="absolute -left-9 top-0 flex items-center justify-center w-6 h-6 ${meta.color} rounded-full text-xs">
                      ${meta.icon}
                    </span>
                    <div class="bg-white rounded-lg border border-gray-200 p-3">
                      <div class="flex items-center justify-between gap-2 mb-1">
                        <span class="text-xs px-2 py-0.5 rounded ${meta.color}">${meta.label}</span>
                        <span class="text-xs text-gray-400">${formatTime(e.timestamp)}</span>
                      </div>
                      <a href="/${escapeHtml(e.category)}/${escapeHtml(e.slug)}/" target="_blank" class="text-sm font-medium text-gray-900 hover:text-deok-700 hover:underline block truncate">
                        ${escapeHtml(e.title)}
                      </a>
                      <div class="text-xs text-gray-500 mt-1 flex items-center gap-2">
                        <span>${escapeHtml(e.category || '-')}</span>
                        ${e.actor ? `<span>· by ${escapeHtml(e.actor)}</span>` : ''}
                        ${e.details ? `<span>· ${escapeHtml(e.details)}</span>` : ''}
                      </div>
                    </div>
                  </li>
                `;
              }).join('')}
            </ol>
          </section>
        `).join('');
      } catch (e) {
        document.getElementById('loading').classList.add('hidden');
        const err = document.getElementById('error');
        err.classList.remove('hidden');
        err.textContent = String(e);
      }
    }

    load();
  </script>
</BaseLayout>
