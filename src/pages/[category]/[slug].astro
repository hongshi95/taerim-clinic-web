---
import { getCollection, getEntry, render } from 'astro:content';
import readingTime from 'reading-time';
import PostLayout from '~/layouts/PostLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', (post) => !post.data.draft);
  return posts.map((post) => {
    const slug = post.id.replace(/\.mdx?$/, '').split('/').pop() ?? post.id;
    return {
      params: { category: post.data.category, slug },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { slug } = Astro.params;

const category = await getEntry('categories', post.data.category);
const author = await getEntry('authors', post.data.author);

if (!category || !author) {
  return Astro.redirect('/404');
}

const { Content } = await render(post);

// 읽기 시간 계산 (본문 body 기준)
const body = post.body ?? '';
const stats = readingTime(body);
const wordCount = stats.words;
const readingMinutes = Math.max(1, Math.ceil(stats.minutes));

// 관련 글: manual relatedPosts(유효한 것만) 우선 + 같은 카테고리 자동 보충, 최대 3
// 통폐합/삭제된 draft 글(hira·guide 등)을 가리키는 깨진 링크는 자동 제거
const allPosts = await getCollection('posts', (p) => !p.data.draft);
const slugOf = (p: (typeof allPosts)[number]) =>
  p.id.replace(/\.mdx?$/, '').split('/').pop() ?? p.id;
const slugFromUrl = (url: string) => url.replace(/\/$/, '').split('/').pop() ?? '';
const validSlugs = new Set(allPosts.map((p) => slugOf(p)));

// frontmatter relatedPosts에서 살아있는 글만 (draft·삭제 링크 제거)
const manualValid = (post.data.relatedPosts ?? []).filter((r) =>
  validSlugs.has(slugFromUrl(r.url))
);
const usedSlugs = new Set(manualValid.map((r) => slugFromUrl(r.url)));

// 같은 카테고리에서 자동 보충 (manual에 없는 글, 최신순)
const autoRelated = allPosts
  .filter(
    (p) =>
      p.data.category === post.data.category &&
      p.id !== post.id &&
      !usedSlugs.has(slugOf(p))
  )
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .map((p) => ({
    url: `/${p.data.category}/${slugOf(p)}/`,
    title: p.data.title,
    summary: p.data.description,
    cat: category.data.name,
  }));

const relatedPosts = [...manualValid, ...autoRelated].slice(0, 3);
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  slug={slug!}
  coverImage={post.data.coverImage}
  coverImageAlt={post.data.coverImageAlt}
  publishedAt={post.data.publishedAt.toISOString()}
  modifiedAt={(post.data.modifiedAt ?? post.data.publishedAt).toISOString()}
  authorName={author.data.name}
  authorSlug={author.id}
  authorBio={author.data.bio}
  authorAvatarUrl={author.data.avatarUrl}
  authorExpertise={author.data.expertise}
  categoryName={category.data.name}
  categorySlug={category.id}
  readingMinutes={readingMinutes}
  quickAnswer={post.data.quickAnswer}
  quickAnswerBullets={post.data.quickAnswerBullets}
  faqs={post.data.faqs}
  wordCount={wordCount}
  schemaType={post.data.schemaType}
  howtoSteps={post.data.howtoSteps}
  howtoTotalTime={post.data.howtoTotalTime}
  citations={post.data.citations}
  relatedPosts={relatedPosts}
>
  <Content />
</PostLayout>
