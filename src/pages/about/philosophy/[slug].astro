---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Header from '~/components/layout/Header.astro';
import Footer from '~/components/layout/Footer.astro';
import { PHILOSOPHY_PRINCIPLES, getAdjacentPrinciples } from '~/data/philosophy';
import { CLINIC } from '~/consts';

export function getStaticPaths() {
  return PHILOSOPHY_PRINCIPLES.map((p) => ({
    params: { slug: p.slug },
    props: { principle: p },
  }));
}

const { principle } = Astro.props;
const { prev, next } = getAdjacentPrinciples(principle.slug);

const title = `${principle.headline} ${principle.headlineEm}${principle.headlineTail ? ' ' + principle.headlineTail : ''} — 진료 철학 ${principle.number}`;
const description = principle.summary;
---

<BaseLayout
  title={`${title} — ${CLINIC.legalName}`}
  description={description}
  type="article"
  canonicalPath={`/about/philosophy/${principle.slug}/`}
>
  <Header />

  {/* Breadcrumb */}
  <nav aria-label="breadcrumb" class="bg-stone-50 border-b border-stone-200">
    <div class="v-container py-4 md:py-5">
      <ol class="flex flex-wrap items-center gap-2 text-[14px] md:text-[15px] text-stone-600">
        <li><a href="/" class="hover:text-green-900">홈</a></li>
        <li aria-hidden="true">/</li>
        <li><a href="/about/" class="hover:text-green-900">원장 소개</a></li>
        <li aria-hidden="true">/</li>
        <li><a href="/about/#philosophy" class="hover:text-green-900">진료 철학</a></li>
        <li aria-hidden="true">/</li>
        <li class="text-stone-900 font-medium">{principle.label}</li>
      </ol>
    </div>
  </nav>

  {/* Hero — 큰 헤드라인 + 사진 */}
  <section class="bg-white">
    <div class="v-container py-16 sm:py-20 md:py-28 lg:py-36">
      <div class={`grid lg:grid-cols-[1.1fr_1fr] gap-10 sm:gap-12 lg:gap-20 items-center ${principle.align === 'left' ? 'lg:[&>figure]:order-1 lg:[&>div]:order-2' : ''}`}>
        <div class="reveal max-w-2xl">
          <div class="flex items-baseline gap-4 mb-7 md:mb-9">
            <span style="color:#15803d;" class="font-serif italic text-4xl md:text-6xl font-bold tabular-nums">{principle.number}</span>
            <span class="text-[13px] md:text-sm font-bold tracking-[0.3em] uppercase text-green-900">
              {principle.label}
            </span>
          </div>

          <h1 class="text-[2.2rem] sm:text-5xl md:text-6xl lg:text-[4.2rem] font-bold text-stone-900 tracking-tight leading-[1.15]">
            {principle.headline}{' '}
            <span class="font-serif italic text-green-900">{principle.headlineEm}</span>
            {principle.headlineTail && (
              <>
                <br class="hidden sm:inline" />
                {' '}{principle.headlineTail}
              </>
            )}
          </h1>

          <p class="mt-8 md:mt-10 text-xl md:text-2xl text-stone-700 leading-[1.7] font-medium">
            {principle.summary}
          </p>
        </div>

        <figure class="reveal">
          <div class="aspect-[4/5] overflow-hidden rounded-sm shadow-2xl shadow-stone-900/20 max-w-md mx-auto lg:max-w-none w-full">
            <img
              src={principle.image}
              alt={principle.imageAlt}
              class="w-full h-full object-cover object-center"
              loading="eager"
              decoding="async"
              width="540"
              height="675"
            />
          </div>
        </figure>
      </div>
    </div>
  </section>

  {/* 본문 — lead + main */}
  <section class="bg-stone-50 border-y border-stone-200">
    <div class="v-container py-16 sm:py-20 md:py-28">
      <div class="reveal max-w-3xl mx-auto">
        <p class="text-2xl md:text-3xl font-bold text-stone-900 leading-[1.5] tracking-tight">
          {principle.bodyLead}
        </p>

        {/* sections — 각 section: 선택적 sub-heading + 단락 */}
        <div class="mt-10 md:mt-14 space-y-10 md:space-y-14">
          {principle.sections.map((section) => (
            <div>
              {section.heading && (
                <h2 class="text-2xl md:text-3xl font-bold text-stone-900 tracking-tight leading-[1.3] mb-6 md:mb-7">
                  <span style="color:#15803d;" class="font-serif italic mr-2">·</span>{section.heading}
                </h2>
              )}
              <div class="space-y-5 md:space-y-6 text-lg md:text-xl text-stone-700 leading-[1.9]">
                {section.paragraphs.map((para) => (
                  <p>{para}</p>
                ))}
              </div>
            </div>
          ))}
        </div>

        {principle.quote && (
          <blockquote class="mt-14 md:mt-20 border-l-4 border-green-800 pl-7 md:pl-9 py-2">
            <p class="text-2xl md:text-3xl lg:text-[2.2rem] font-bold text-green-900 italic leading-[1.5] tracking-tight">
              {principle.quote}
            </p>
            <footer class="mt-4 text-sm md:text-base text-stone-500 tracking-[0.15em] uppercase">
              — {principle.quoteSource || '서조혁 원장'}
            </footer>
          </blockquote>
        )}

        {principle.caseStudy && (
          <div class="mt-14 md:mt-20 bg-white border border-green-200 p-7 md:p-10 rounded-sm">
            <div class="text-[13px] md:text-sm font-bold tracking-[0.25em] uppercase text-green-900 mb-4">
              실제 진료 사례
            </div>
            <h2 class="text-2xl md:text-3xl font-bold text-stone-900 tracking-tight">
              {principle.caseStudy.title}
            </h2>
            <p class="mt-5 text-[17px] md:text-lg text-stone-700 leading-[1.85]">
              {principle.caseStudy.body}
            </p>
          </div>
        )}
      </div>
    </div>
  </section>

  {/* 다음/이전 원칙 navigation */}
  <section class="bg-white">
    <div class="v-container py-12 md:py-16">
      <div class="max-w-5xl mx-auto grid sm:grid-cols-2 gap-4 md:gap-6">
        {prev ? (
          <a href={`/about/philosophy/${prev.slug}/`} class="group block bg-stone-50 hover:bg-green-50 p-6 md:p-7 border border-stone-200 hover:border-green-300 transition-all">
            <div class="text-[12px] md:text-[13px] font-bold tracking-[0.25em] uppercase text-stone-500 mb-3">
              ← 이전 원칙 · {prev.number}
            </div>
            <div class="text-lg md:text-xl font-bold text-stone-900 group-hover:text-green-900 transition-colors">
              {prev.label} · {prev.headline} {prev.headlineEm}
            </div>
          </a>
        ) : <div></div>}

        {next ? (
          <a href={`/about/philosophy/${next.slug}/`} class="group block bg-stone-50 hover:bg-green-50 p-6 md:p-7 border border-stone-200 hover:border-green-300 transition-all text-right">
            <div class="text-[12px] md:text-[13px] font-bold tracking-[0.25em] uppercase text-stone-500 mb-3">
              다음 원칙 · {next.number} →
            </div>
            <div class="text-lg md:text-xl font-bold text-stone-900 group-hover:text-green-900 transition-colors">
              {next.label} · {next.headline} {next.headlineEm}
            </div>
          </a>
        ) : <div></div>}
      </div>

      <div class="mt-10 md:mt-12 text-center">
        <a href="/about/" class="inline-flex items-center gap-2 text-[16px] md:text-lg font-bold text-green-900 hover:text-green-700 transition-colors">
          <span aria-hidden="true">←</span> 원장 소개로 돌아가기
        </a>
      </div>

      {/* 의료법 디스클레이머 — 모든 진료 철학 페이지 공통 */}
      <aside class="mt-12 md:mt-16 max-w-3xl mx-auto bg-stone-50 border border-stone-200 p-6 md:p-7 text-[14px] md:text-[15px] text-stone-600 leading-[1.85]">
        <div class="text-[11px] md:text-xs font-bold tracking-[0.25em] uppercase text-stone-500 mb-3">
          알려드립니다
        </div>
        <ul class="space-y-2 list-disc pl-5">
          <li>본 페이지는 태림한의원의 진료 철학을 안내드리는 일반 정보이며, 진단·처방은 반드시 진료를 통해 이뤄집니다.</li>
          <li>인용된 사례는 환자분의 동의를 받은 경우에 한해 정리되었으며, 환자마다 치료 접근 방식과 예후가 다를 수 있습니다.</li>
          <li>치료 효과는 개인차가 있으며, "완치", "100%", "부작용 없음" 같은 단정적 표현은 사용하지 않습니다.</li>
        </ul>
      </aside>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1), transform 0.9s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal.in-view {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script is:inline>
  (function () {
    if (typeof window === 'undefined') return;
    const reduce = window.matchMedia?.('(prefers-reduced-motion: reduce)')?.matches;
    if (reduce) {
      document.querySelectorAll('.reveal').forEach((el) => el.classList.add('in-view'));
      return;
    }
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add('in-view');
            io.unobserve(e.target);
          }
        }
      },
      { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
    );
    document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
  })();
</script>
