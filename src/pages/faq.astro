---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Header from '~/components/layout/Header.astro';
import Footer from '~/components/layout/Footer.astro';
import Breadcrumb from '~/components/layout/Breadcrumb.astro';
import { SITE, CLINIC } from '~/consts';

const posts = await getCollection('posts', (p) => !p.data.draft);
const categories = (await getCollection('categories')).sort(
  (a, b) => a.data.order - b.data.order
);

// 카테고리별 FAQ 수집 (각 글의 faqs를 원본 글 링크와 함께)
type FaqItem = { q: string; a: string; postTitle: string; postUrl: string };
const faqsByCategory: { catName: string; catId: string; faqs: FaqItem[] }[] = [];

for (const cat of categories) {
  const catPosts = posts.filter((p) => p.data.category === cat.id);
  const faqs: FaqItem[] = [];
  for (const post of catPosts) {
    const slug = post.id.replace(/\.mdx?$/, '').split('/').pop();
    for (const f of post.data.faqs ?? []) {
      faqs.push({
        q: f.q,
        a: f.a,
        postTitle: post.data.title,
        postUrl: `/${cat.id}/${slug}/`,
      });
    }
  }
  if (faqs.length > 0) {
    faqsByCategory.push({ catName: cat.data.name, catId: cat.id, faqs });
  }
}

const allFaqs = faqsByCategory.flatMap((g) => g.faqs);

// FAQPage schema (AEO/GEO - Gemini·ChatGPT 답변 인용 신호)
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${SITE.url}/faq/#faqpage`,
  name: `자주 묻는 질문 - ${CLINIC.legalName}`,
  mainEntity: allFaqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const title = '자주 묻는 질문 - 태림한의원 진료 안내';
const description = `${CLINIC.legalName} 진료 관련 자주 묻는 질문 ${allFaqs.length}개를 통증·다이어트·교통사고·체질·소아 진료별로 정리했습니다. 대구 달서구 진천역.`;
---

<BaseLayout title={title} description={description} type="website" canonicalPath="/faq/">
  <slot name="head" slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </slot>

  <Header />

  <Breadcrumb items={[{ name: '자주 묻는 질문', href: '/faq/' }]} />

  <main class="v-container py-10 md:py-14">
    <header class="mb-10 md:mb-14 max-w-2xl">
      <div
        class="text-[11px] font-bold tracking-[0.25em] uppercase text-green-900 mb-3"
        style="font-family: var(--font-display);"
      >
        FAQ
      </div>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-stone-900 tracking-tight leading-[1.2]">
        자주 묻는 질문
      </h1>
      <p class="mt-4 text-lg text-stone-600 leading-relaxed">
        진료 전 환자분들이 가장 많이 물어보시는 질문을 진료 영역별로 모았습니다. 더 자세한 내용은 각 질문 아래 글에서 확인하실 수 있습니다.
      </p>
    </header>

    {/* 카테고리 빠른 이동 */}
    <nav class="mb-12 flex flex-wrap gap-2" aria-label="진료 영역별 FAQ 바로가기">
      {faqsByCategory.map((g) => (
        <a
          href={`#faq-${g.catId}`}
          class="px-4 py-2 rounded-full bg-stone-100 text-stone-700 text-sm font-semibold hover:bg-green-50 hover:text-green-900 transition-colors"
        >
          {g.catName} ({g.faqs.length})
        </a>
      ))}
    </nav>

    {/* 카테고리별 FAQ 아코디언 */}
    <div class="space-y-12 max-w-3xl">
      {faqsByCategory.map((g) => (
        <section id={`faq-${g.catId}`} class="scroll-mt-24">
          <h2 class="text-xl md:text-2xl font-bold text-stone-900 tracking-tight mb-5 pb-3 border-b border-stone-200">
            {g.catName}
          </h2>
          <div class="space-y-3">
            {g.faqs.map((f) => (
              <details class="group rounded-xl bg-white ring-1 ring-stone-200 overflow-hidden">
                <summary class="flex items-start gap-3 cursor-pointer list-none p-5 hover:bg-stone-50 transition-colors">
                  <span
                    aria-hidden="true"
                    style="color:#15803d;"
                    class="shrink-0 mt-0.5 font-bold text-lg leading-none"
                  >
                    Q
                  </span>
                  <span class="flex-1 font-bold text-stone-900 leading-snug text-[16px] md:text-[17px]">
                    {f.q}
                  </span>
                  <svg
                    aria-hidden="true"
                    class="shrink-0 w-5 h-5 text-stone-400 mt-0.5 transition-transform group-open:rotate-180"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polyline points="6 9 12 15 18 9"></polyline>
                  </svg>
                </summary>
                <div class="px-5 pb-5 pl-[2.85rem]">
                  <p class="text-[15px] md:text-base text-stone-700 leading-[1.8]">
                    {f.a}
                  </p>
                  <a
                    href={f.postUrl}
                    class="mt-3 inline-flex items-center gap-1.5 text-sm font-semibold text-green-800 hover:text-green-900"
                  >
                    자세히 보기, {f.postTitle}
                    <span aria-hidden="true">→</span>
                  </a>
                </div>
              </details>
            ))}
          </div>
        </section>
      ))}
    </div>

    {/* CTA */}
    <aside class="mt-16 p-6 md:p-8 rounded-2xl bg-gradient-to-br from-green-50 via-stone-50 to-green-50 ring-1 ring-green-200/60 max-w-3xl">
      <h2 class="text-xl md:text-2xl font-bold text-stone-900 mb-2">
        찾으시는 답이 없으신가요?
      </h2>
      <p class="text-stone-600 leading-relaxed mb-5 text-[15px] md:text-base">
        진료 관련 궁금한 점은 전화 또는 네이버 플레이스로 문의해 주세요. 정확한 진단·처방은 진료를 통해 안내드립니다.
      </p>
      <div class="flex flex-wrap gap-2.5">
        {CLINIC.naverPlaceUrl && (
          <a
            href={CLINIC.naverPlaceUrl}
            target="_blank"
            rel="noopener"
            style="color:#ffffff;background-color:#15803d;"
            class="inline-flex items-center gap-2 px-5 py-3 rounded-full text-[15px] font-bold hover:bg-green-900 shadow-lg shadow-green-900/20"
          >
            네이버 플레이스에서 예약
            <span aria-hidden="true">→</span>
          </a>
        )}
        {CLINIC.phone && (
          <a
            href={`tel:${CLINIC.phone}`}
            class="inline-flex items-center gap-2 px-5 py-3 rounded-full bg-white text-green-900 text-[15px] font-bold border border-green-200 hover:bg-green-50 tabular-nums"
          >
            {CLINIC.phone}
          </a>
        )}
        <a
          href="/visit/"
          class="inline-flex items-center gap-2 px-5 py-3 rounded-full bg-white text-stone-700 text-[15px] font-bold border border-stone-300 hover:bg-stone-100"
        >
          오시는길
        </a>
      </div>
    </aside>
  </main>

  <Footer />
</BaseLayout>
