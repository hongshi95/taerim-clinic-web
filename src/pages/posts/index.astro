---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Header from '~/components/layout/Header.astro';
import Footer from '~/components/layout/Footer.astro';
import Breadcrumb from '~/components/layout/Breadcrumb.astro';
import { SITE } from '~/consts';

// 전체 글 아카이브 - 날짜 역순. 누락 없이 전부 표시.
const categories = (await getCollection('categories')).sort(
  (a, b) => a.data.order - b.data.order
);
const allPosts = (await getCollection('posts', (p) => !p.data.draft)).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);

// 카테고리별 통계 (탭 바에 카운트 표시용)
const countByCategory: Record<string, number> = {};
for (const p of allPosts) {
  countByCategory[p.data.category] = (countByCategory[p.data.category] ?? 0) + 1;
}

// 월별 그룹핑 (쉬운 탐색)
type PostEntry = (typeof allPosts)[number];
const groupedByMonth = new Map<string, PostEntry[]>();
for (const p of allPosts) {
  const key = `${p.data.publishedAt.getFullYear()}년 ${p.data.publishedAt.getMonth() + 1}월`;
  (groupedByMonth.get(key) ?? groupedByMonth.set(key, []).get(key)!).push(p);
}

const fmtDate = (d: Date) => d.toLocaleDateString('ko-KR', { month: 'long', day: 'numeric' });
const slugOf = (p: PostEntry) => p.id.replace(/\.mdx?$/, '').split('/').pop();
---

<BaseLayout
  title={`전체 글 (${allPosts.length}편) - ${SITE.name}`}
  description={`${SITE.name}에서 발행한 모든 실측 리뷰 ${allPosts.length}편. 자동차·연애·자기관리 카테고리별 전체 글을 날짜순으로 모았습니다.`}
  type="website"
  canonicalPath="/posts/"
>
  <Header />

  <Breadcrumb items={[{ name: '전체 글', href: '/posts/' }]} />

  <main class="v-container py-8 md:py-10">
    {/* 헤더 */}
    <header class="mb-8 pb-6 border-b border-gray-100">
      <div class="inline-block px-3 py-1 rounded-full bg-deok-100 text-deok-700 text-[11px] font-bold tracking-wide mb-3">
        ARCHIVE
      </div>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-gray-900">
        전체 글 <span class="text-deok-600">{allPosts.length}편</span>
      </h1>
      <p class="mt-3 text-sm md:text-base text-gray-600">
        실측·검증 완료된 모든 리뷰를 날짜 순으로 모았습니다.
      </p>
    </header>

    {/* 카테고리 필터 칩 */}
    <div class="flex items-center gap-2 flex-wrap mb-8">
      <span class="px-3 py-1.5 rounded-full bg-deok-600 text-white text-xs font-semibold">
        전체 {allPosts.length}
      </span>
      {categories.map((cat) => (
        <a
          href={`/${cat.id}/`}
          class="px-3 py-1.5 rounded-full bg-gray-100 hover:bg-deok-50 hover:text-deok-700 text-gray-700 text-xs font-medium transition-colors"
        >
          {cat.data.name} ({countByCategory[cat.id] ?? 0})
        </a>
      ))}
    </div>

    {/* 월별 섹션 */}
    <div class="space-y-10">
      {Array.from(groupedByMonth.entries()).map(([month, posts]) => (
        <section>
          <div class="flex items-baseline gap-3 mb-4 pb-2 border-b border-gray-100">
            <h2 class="text-lg md:text-xl font-bold text-gray-900">{month}</h2>
            <span class="text-xs text-gray-500">{posts.length}편</span>
          </div>

          <ul class="grid gap-4 md:gap-5 md:grid-cols-2 lg:grid-cols-3">
            {posts.map(async (post) => {
              const category = await getEntry('categories', post.data.category);
              const slug = slugOf(post);
              return (
                <li>
                  <a
                    href={`/${post.data.category}/${slug}/`}
                    class="group flex h-full rounded-xl border border-gray-200 bg-white overflow-hidden transition-all hover:border-deok-300 hover:shadow-md"
                  >
                    {/* 썸네일 */}
                    <div class="w-24 md:w-28 shrink-0 bg-gray-100 overflow-hidden">
                      {post.data.coverImage ? (
                        <img
                          src={post.data.coverImage}
                          alt={post.data.coverImageAlt ?? post.data.title}
                          class="w-full h-full object-cover group-hover:scale-105 transition-transform"
                          loading="lazy"
                          decoding="async"
                        />
                      ) : (
                        <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-deok-100 via-deok-50 to-stone-50">
                          <span
                            class="text-[9px] font-bold tracking-[0.2em] uppercase text-deok-700 text-center px-1"
                            style="font-family: var(--font-display);"
                          >
                            {category?.data.name ?? ''}
                          </span>
                        </div>
                      )}
                    </div>

                    {/* 본문 */}
                    <div class="flex-1 p-3 md:p-4 min-w-0">
                      <div class="flex items-center gap-1.5 mb-1.5">
                        {category && (
                          <span class="text-[10px] font-semibold text-deok-600">
                            {category.data.name}
                          </span>
                        )}
                        {post.data.featured && (
                          <span class="text-[9px] font-bold text-green-700 tracking-wider uppercase">대표</span>
                        )}
                      </div>
                      <h3 class="font-bold text-sm text-gray-900 leading-snug group-hover:text-deok-700 line-clamp-2">
                        {post.data.title}
                      </h3>
                      <time class="mt-2 block text-[10px] text-gray-400" datetime={post.data.publishedAt.toISOString()}>
                        {fmtDate(post.data.publishedAt)}
                      </time>
                    </div>
                  </a>
                </li>
              );
            })}
          </ul>
        </section>
      ))}
    </div>

    {/* 비어있을 때 */}
    {allPosts.length === 0 && (
      <div class="py-16 text-center text-gray-500">
        아직 발행된 글이 없습니다.
      </div>
    )}
  </main>

  <Footer />
</BaseLayout>
