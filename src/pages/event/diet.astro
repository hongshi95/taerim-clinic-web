<script is:inline define:vars={{ eventEnd: EVENT.end }}>
  (() => {
    try {
      const el = document.getElementById('lp-dday');
      if (el && eventEnd) {
        const end = new Date(eventEnd + 'T23:59:59+09:00');
        const days = Math.ceil((end.getTime() - Date.now()) / 86400000);
        if (days >= 0) el.textContent = days === 0 ? '오늘 마감' : 'D-' + days;
      }
    } catch {}

    const OUTBOX = 'taerim_consult_outbox_v1';
    const forms = document.querySelectorAll('.lp-form');
    if (!forms.length) return;

    const readOutbox = () => { try { const v = JSON.parse(localStorage.getItem(OUTBOX) || '[]'); return Array.isArray(v) ? v : []; } catch { return []; } };
    const writeOutbox = (l) => { try { localStorage.setItem(OUTBOX, JSON.stringify(l)); } catch {} };
    const addOutbox = (x) => { const l = readOutbox().filter((i) => i.id !== x.id); l.push(x); writeOutbox(l); };
    const rmOutbox = (id) => writeOutbox(readOutbox().filter((i) => i.id !== id));
    const genId = () => { try { if (crypto && crypto.randomUUID) return crypto.randomUUID(); } catch {} return 'x' + Date.now().toString(36) + Math.random().toString(36).slice(2, 8); };
    const nowKST = () => { try { return new Date().toLocaleString('ko-KR', { timeZone: 'Asia/Seoul' }); } catch { return new Date().toISOString(); } };

    async function deliver(lead) {
      try {
        const res = await fetch('/api/consult', {
          method: 'POST',
          headers: { 'Content-Type': 'text/plain;charset=utf-8' },
          body: JSON.stringify(lead),
          keepalive: true,
        });
        if (!res.ok) return false;
        const d = await res.json().catch(() => null);
        return !!(d && d.ok);
      } catch { return false; }
    }

    let flushing = false;
    async function flush() {
      if (flushing) return;
      flushing = true;
      try { for (const l of readOutbox()) { if (await deliver(l)) rmOutbox(l.id); } }
      finally { flushing = false; }
    }

    forms.forEach((form) => {
      const nameEl = form.querySelector('.lp-name');
      const phoneEl = form.querySelector('.lp-phone');
      const checkEl = form.querySelector('.lp-check');
      const errEl = form.querySelector('.lp-err');
      const doneEl = form.querySelector('.lp-done');
      const submitEl = form.querySelector('.lp-submit');
      const policyEl = form.querySelector('.lp-policy');
      const toggleEl = form.querySelector('.lp-policy-toggle');
      const source = form.getAttribute('data-source') || '다이어트 랜딩';

      phoneEl.addEventListener('input', (e) => { e.target.value = e.target.value.replace(/\D/g, ''); });
      toggleEl.addEventListener('click', () => { policyEl.hidden = !policyEl.hidden; });

      function showDone(ok) {
        form.querySelectorAll('.field, .lp-agree, .lp-policy, .lp-submit, .lp-err').forEach((n) => { n.style.display = 'none'; });
        doneEl.hidden = false;
        doneEl.innerHTML = ok
          ? '<strong>상담 신청이 접수되었습니다.</strong><span>남겨주신 연락처로 한의원에서 직접 전화드리겠습니다.</span>'
          : '<strong>전송이 잠시 지연되고 있어요.</strong><span>자동으로 다시 보내는 중입니다. 잠시 후 다시 시도하거나, 다시 신청해 주세요.</span>';
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        errEl.hidden = true;
        const name = nameEl.value.trim();
        const phone = phoneEl.value.replace(/\D/g, '');
        if (!name) { errEl.textContent = '이름을 입력해 주세요.'; errEl.hidden = false; return; }
        if (phone.length < 10) { errEl.textContent = '연락처를 정확히 입력해 주세요.'; errEl.hidden = false; return; }
        if (!checkEl.checked) { errEl.textContent = '개인정보 수집·이용에 동의해 주세요.'; errEl.hidden = false; return; }

        submitEl.disabled = true; submitEl.textContent = '전송 중...';
        const lead = { id: genId(), time: nowKST(), name, phone, source };
        addOutbox(lead);
        const ok = await deliver(lead);
        if (ok) rmOutbox(lead.id);
        showDone(ok);

        if (!ok) {
          let delay = 5000;
          const tick = async () => { await flush(); if (readOutbox().length) { delay = Math.min(delay * 2, 300000); setTimeout(tick, delay); } };
          setTimeout(tick, delay);
        }
      });
    });

    window.addEventListener('online', () => { void flush(); });
    setTimeout(() => { void flush(); }, 2500);
  })();
</script>
