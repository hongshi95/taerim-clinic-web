---
// ────────────────────────────────────────────────────────────
// 다이어트 광고 전용 랜딩페이지 (폐쇄형 / DB 수집형) — v3 라이트·뷰티 리디자인
//   - 광고로만 진입. noindex + 사이트맵 미포함 + 비링크 = 검색 노출 안 됨.
//   - 전환 = 이름·연락처 수집(/api/consult, source='다이어트 랜딩') → 한의원이 전화.
//   - 톤: 크림/화이트 + 은은한 코랄·로즈(살구) 뷰티 포인트. 녹색·다크밴드 없음.
//   - 포맷: 통상 다이어트 LP 흐름(고민 공감 → 혜택 → 솔루션 → 원장 → 과정 → 상담).
//   - 의료법 준수: 효과 단정·최상급·"부작용 없음"·후기·kg수치 금지. 의료기관 명칭·주소·연락처는 법적 표기 의무.
// ────────────────────────────────────────────────────────────
import BaseLayout from '~/layouts/BaseLayout.astro';
import { CLINIC } from '~/consts';

// ⚠️⚠️ 광고 집행 전 반드시 교체 ⚠️⚠️ (아래 값은 예시 placeholder)
const EVENT = {
  target: '산후 6개월 이내 · 한약 다이어트 첫 상담 고객',
  period: '2026.07.01 – 07.31',
  end: '2026-07-31',
  normalPrice: '396,000',
  eventPrice: '297,000',
  unit: '1개월 한약 다이어트 프로그램 · 건강보험 비급여',
};

const SOURCE = '다이어트 랜딩';

const PRIVACY =
  `수집 항목: 이름, 연락처 · 수집·이용 목적: 상담 신청 접수 및 진료·예약 안내 연락 · ` +
  `보유·이용 기간: 상담 완료 후 6개월 이내 파기(동의 철회 시 지체 없이 파기) · ` +
  `수집·이용 주체: ${CLINIC.legalName} · ` +
  `동의를 거부하실 수 있으며, 이 경우 온라인 상담 접수가 제한될 수 있습니다(전화로는 언제든 상담 가능).`;
---

<BaseLayout
  title="한약 다이어트 1:1 상담 안내"
  description="체질·식습관·대사 패턴을 1:1로 확인해 요요를 줄이는 방향으로 설계하는 한약 다이어트 상담 안내."
  image="/og-diet-v2.jpg"
  noIndex={true}
>
  <main class="lp">
    {/* 상단 바 */}
    <header class="topbar">
      <span class="brand">한방 다이어트</span>
      <a href="#apply" class="topbar-cta">상담 신청 <span aria-hidden="true">→</span></a>
    </header>

    {/* HERO */}
    <section class="hero">
      <span class="badge rise" style="--d:.05s">산후 · 체질 다이어트</span>
      <h1 class="hero-h1 rise" style="--d:.12s">
        굶지 않고,<br />
        <b>체질부터</b> 관리하는<br />
        한약 다이어트
      </h1>
      <p class="hero-sub rise" style="--d:.2s">
        같은 식단에도 잘 안 빠지는 이유는 체질마다 다릅니다.
        한의사가 1:1로 확인하고, 요요를 줄이는 방향으로 설계해 드려요.
      </p>

      <figure class="hero-photo rise" style="--d:.3s">
        <img src="/images/clinic/diet-lp-hero.webp" alt="태림한의원 서조혁 원장" width="1024" height="768" fetchpriority="high" decoding="async" />
      </figure>

      <div class="hero-cta rise" style="--d:.4s">
        <a href="#apply" class="btn btn-accent full">1:1 상담 신청하기</a>
      </div>
    </section>

    {/* 고민 공감 */}
    <section class="worries">
      <div class="wrap" data-reveal>
        <p class="eyebrow">CHECK</p>
        <h2 class="h2">혹시, 이런 고민 있으세요?</h2>
        <ul class="worry-list">
          {[
            '다이어트만 하면 요요가 반복돼요',
            '물만 먹어도 붓고 잘 안 빠져요',
            '출산 후 몸이 예전 같지 않아요',
            '굶는 다이어트는 더는 못 하겠어요',
            '나에게 맞는 방법을 모르겠어요',
          ].map((w) => (
            <li>
              <svg class="chk" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>{w}</span>
            </li>
          ))}
        </ul>
        <p class="worry-foot">한 가지라도 해당된다면, 체질부터 확인해 보세요.</p>
      </div>
    </section>

    {/* 이벤트 혜택 */}
    <section class="wrap">
      <div class="promo" data-reveal>
        <span class="promo-tag">기간 한정 상담 혜택 <b id="lp-dday">{EVENT.period}</b></span>
        <div class="promo-price">
          <span class="was">정상가 {EVENT.normalPrice}원</span>
          <span class="now-label">이벤트가</span>
          <span class="now"><b>{EVENT.eventPrice}</b>원</span>
        </div>
        <dl class="promo-dl">
          <div><dt>대상</dt><dd>{EVENT.target}</dd></div>
          <div><dt>기간</dt><dd>{EVENT.period}</dd></div>
          <div><dt>구성</dt><dd>{EVENT.unit}</dd></div>
        </dl>
        <p class="promo-note">효과·감량 정도·소요 기간은 개인의 체질과 생활습관에 따라 다를 수 있습니다.</p>
        <a href="#apply" class="btn btn-accent full">상담 신청하고 혜택 받기</a>
      </div>
    </section>

    {/* 솔루션 / 프로그램 */}
    <section class="wrap prog">
      <div data-reveal>
        <p class="eyebrow">PROGRAM</p>
        <h2 class="h2">상담 후, 이렇게 진행돼요</h2>
      </div>
      <div class="pcards">
        {[
          { img: '/images/clinic/herbal-preparation.png', t: '체질 맞춤 한약', d: '체질·대사 패턴에 맞춰 처방을 설계합니다. 복용 중인 약·건강 상태를 진료 시 함께 확인합니다.' },
          { img: '/images/clinic/maesun-threads.webp', t: '매선 체형 케어', d: '한방 매선(녹는 실)으로 부위별 라인을 정리합니다. 필요 여부는 진단 후 결정합니다.' },
          { img: '/images/clinic/diet-lp-consult.webp', t: '식이·생활 코칭', d: '굶는 식단이 아니라, 지속 가능한 식습관·생활 리듬을 함께 잡습니다.' },
        ].map((p, i) => (
          <article class="pcard" data-reveal data-reveal-delay={Math.min(i + 1, 5)}>
            <figure><img src={p.img} alt={p.t} loading="lazy" decoding="async" /></figure>
            <div class="pcard-txt">
              <h3>{p.t}</h3>
              <p>{p.d}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    {/* 원장 직접 진료 */}
    <section class="wrap">
      <div class="doctor" data-reveal>
        <img src="/images/clinic/diet-lp-director.webp" alt="서조혁 원장" width="480" height="480" loading="lazy" decoding="async" />
        <div class="doctor-txt">
          <span class="badge sm">대표원장 직접 진료</span>
          <h3>서조혁 <b>원장</b></h3>
          <p>정해진 패키지를 똑같이 드리지 않습니다. 한 사람의 체질과 생활을 먼저 살피고, 한약·매선·식이를 상태에 맞춰 조합합니다.</p>
        </div>
      </div>
    </section>

    {/* 진행 과정 */}
    <section class="wrap steps">
      <div data-reveal>
        <p class="eyebrow">PROCESS</p>
        <h2 class="h2">신청부터 진료까지</h2>
      </div>
      <ol data-reveal>
        {[
          { t: '상담 신청', d: '이름·연락처만 남기면 끝.' },
          { t: '전화 상담', d: '한의원에서 직접 연락드려 상태를 간단히 확인해요.' },
          { t: '내원 진단', d: '체질·생활습관을 진료로 자세히 확인합니다.' },
          { t: '맞춤 설계', d: '한약·매선·식이 계획을 함께 정합니다.' },
        ].map((s, i) => (
          <li><span class="sn">{i + 1}</span><div><b>{s.t}</b><p>{s.d}</p></div></li>
        ))}
      </ol>
    </section>

    {/* CTA 배너 (원장 누끼) */}
    <section class="cta-banner">
      <div class="cta-inner" data-reveal>
        <div class="cta-txt">
          <h2>지금 신청하면<br />대표원장이 <b>직접 진료</b></h2>
          <p>비용·예약 강요 없이, 궁금한 점부터 편하게.</p>
          <a href="#apply" class="btn btn-accent">상담 신청하기</a>
        </div>
        <figure class="cta-doc">
          <img src="/images/clinic/diet-lp-cutout.webp" alt="서조혁 원장" width="610" height="1563" loading="lazy" decoding="async" />
        </figure>
      </div>
    </section>

    {/* FAQ */}
    <section class="wrap faq-sec">
      <div data-reveal>
        <p class="eyebrow">FAQ</p>
        <h2 class="h2">자주 묻는 질문</h2>
      </div>
      <div class="faq" data-reveal>
        {[
          { q: '한약 다이어트, 굶어야 하나요?', a: '아니요. 극단적 절식보다 식이·생활 습관 상담을 함께 진행합니다. 무리한 단식은 권하지 않습니다.' },
          { q: '요요가 오지 않나요?', a: '개인차가 있습니다. 감량 이후 유지 단계까지 상담해 다시 찌는 패턴을 줄이는 데 중점을 둡니다.' },
          { q: '부작용이 걱정돼요.', a: '한의사가 체질과 복용 중인 약·건강 상태를 확인한 뒤 처방합니다. 진료 시 충분히 상담해 드립니다.' },
          { q: '수유 중인데 가능한가요?', a: '수유·임신·기저질환 여부는 진료 시 개별적으로 확인 후 결정합니다. 상담 시 꼭 알려주세요.' },
          { q: '상담만 받아도 되나요?', a: '네. 비용이나 시술을 강요하지 않습니다. 궁금한 점만 확인하셔도 괜찮습니다.' },
        ].map((f) => (
          <details class="qa">
            <summary><span>{f.q}</span><i aria-hidden="true"></i></summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    {/* 상담 신청 폼 */}
    <section id="apply" class="wrap apply">
      <div data-reveal>
        <p class="eyebrow">APPLY</p>
        <h2 class="h2">1:1 상담 신청</h2>
        <p class="apply-sub">연락처만 남기면, 한의원에서 직접 전화드려요.</p>
      </div>

      <form class="lp-form" data-source={SOURCE} data-reveal>
        <div class="field">
          <label class="lp-label">이름</label>
          <input class="lp-input lp-name" type="text" placeholder="성함" maxlength="20" autocomplete="name" aria-label="이름" />
        </div>
        <div class="field">
          <label class="lp-label">연락처</label>
          <input class="lp-input lp-phone" type="tel" inputmode="numeric" maxlength="11" placeholder="010 0000 0000" autocomplete="tel" aria-label="연락처" />
        </div>

        <label class="lp-agree">
          <input type="checkbox" class="lp-check" />
          <span>개인정보 수집·이용 동의</span>
          <button type="button" class="lp-policy-toggle">자세히</button>
        </label>
        <div class="lp-policy" hidden>{PRIVACY}</div>

        <button type="submit" class="btn btn-accent full lp-submit">상담 신청하기</button>

        <p class="lp-err" role="alert" hidden></p>
        <div class="lp-done" role="status" hidden></div>
      </form>
    </section>

    {/* 법적 고지 */}
    <footer class="legal">
      <p class="legal-name">{CLINIC.legalName} · 대표원장 {CLINIC.doctorName} {CLINIC.doctorTitle}</p>
      <p class="legal-addr">{CLINIC.address.addressLocality} {CLINIC.address.streetAddress}</p>
      <p class="legal-body">
        본 페이지는 {CLINIC.legalName}의 의료광고입니다. 게시된 내용은 진료 안내를 위한 것으로,
        치료 효과·감량 정도·소요 기간은 개인의 체질과 상태에 따라 다를 수 있으며 의학적 판단은 진료를 통해 이루어집니다.
        이벤트 금액은 건강보험 비급여 항목으로, 표시된 대상·기간에 한해 적용됩니다.
      </p>
      <p class="legal-tiny">의료광고 심의필 제□□□□-□□□호 (※ 심의 대상 시 심의번호 기재)</p>
    </footer>

    {/* 모바일 고정 CTA */}
    <div class="lp-mobilebar">
      <a href="#apply" class="mb-cta">1:1 상담 신청하기</a>
    </div>
  </main>
</BaseLayout>

<style is:global>
  :root {
    --bg: #fcf8f5;
    --bg-soft: #fbeee9;
    --bg-card: #ffffff;
    --ink: #403834;
    --ink-soft: #8b817b;
    --ink-faint: #b6aca6;
    --accent: #e08b83;
    --accent-deep: #cf736a;
    --accent-soft: #fbe6e0;
    --line: #f1e4de;
    --gutter: #efe1db;
    --radius: 18px;
    --shadow: 0 16px 38px -18px rgba(180, 110, 100, 0.32);
    --shadow-sm: 0 8px 22px -12px rgba(180, 110, 100, 0.26);
    --ease: cubic-bezier(0.16, 1, 0.3, 1);
  }
  html { background: var(--bg); }
  body { background: var(--bg); color: var(--ink); }
  html.has-tc-consult body { padding-bottom: 0; }
  @media (min-width: 540px) {
    html, body { background: var(--gutter); }
  }
</style>

<style>
  .lp {
    max-width: 480px;
    margin: 0 auto;
    padding: 0 0 96px;
    background: var(--bg);
    color: var(--ink);
    overflow-x: clip;
    line-height: 1.6;
  }
  .wrap { padding-left: 22px; padding-right: 22px; }

  /* 공통 타이포 */
  .eyebrow {
    font-size: 11.5px;
    font-weight: 800;
    letter-spacing: 0.18em;
    color: var(--accent-deep);
    margin: 0 0 8px;
  }
  .h2 {
    font-size: clamp(1.4rem, 6vw, 1.75rem);
    font-weight: 800;
    line-height: 1.36;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0 0 22px;
    word-break: keep-all;
  }
  .badge {
    display: inline-block;
    background: var(--accent-soft);
    color: var(--accent-deep);
    font-size: 12.5px;
    font-weight: 700;
    padding: 7px 14px;
    border-radius: 999px;
  }
  .badge.sm { font-size: 11.5px; padding: 5px 11px; }

  /* 버튼 */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    height: 54px;
    padding: 0 24px;
    border: 0;
    border-radius: 14px;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    transition: transform 0.2s var(--ease), background-color 0.2s var(--ease), box-shadow 0.2s var(--ease);
  }
  .btn.full { width: 100%; }
  .btn-accent {
    background: var(--accent);
    color: #fff;
    box-shadow: 0 12px 24px -10px rgba(224, 139, 131, 0.7);
  }
  .btn-accent:hover { background: var(--accent-deep); }
  .btn-accent:active { transform: translateY(1px); }
  .btn-ghost {
    background: #fff;
    color: var(--accent-deep);
    border: 1px solid var(--line);
  }
  .btn-ghost:hover { background: var(--accent-soft); }

  /* 상단 바 */
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 15px 22px;
  }
  .brand { font-size: 14px; font-weight: 800; color: var(--ink); letter-spacing: -0.01em; }
  .topbar-cta {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 13px;
    font-weight: 700;
    color: var(--accent-deep);
  }

  /* HERO */
  .hero { padding: 14px 22px 40px; }
  .hero-h1 {
    font-size: clamp(1.85rem, 8.6vw, 2.5rem);
    font-weight: 800;
    line-height: 1.32;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin: 16px 0 0;
  }
  .hero-h1 b { color: var(--accent-deep); font-weight: 800; }
  .hero-sub {
    margin: 16px 0 0;
    font-size: 15px;
    line-height: 1.75;
    color: var(--ink-soft);
    word-break: keep-all;
  }
  .hero-photo { margin: 26px 0 0; }
  .hero-photo img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    object-position: center 42%;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    display: block;
  }
  .hero-cta { display: flex; gap: 10px; margin-top: 22px; }
  .hero-cta .btn-accent { flex: 1; }
  .hero-cta .btn-ghost { flex: none; padding: 0 20px; }

  /* 고민 공감 */
  .worries { margin-top: 20px; background: var(--bg-soft); padding: 44px 0; }
  .worry-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 10px; }
  .worry-list li {
    display: flex;
    align-items: center;
    gap: 12px;
    background: #fff;
    border-radius: 13px;
    padding: 15px 16px;
    font-size: 15px;
    font-weight: 500;
    color: var(--ink);
    box-shadow: var(--shadow-sm);
  }
  .worry-list .chk {
    width: 19px; height: 19px;
    flex: none;
    color: var(--accent);
  }
  .worry-foot { margin: 20px 0 0; font-size: 14px; color: var(--ink-soft); text-align: center; }

  /* 이벤트 혜택 */
  .promo {
    margin-top: 44px;
    background: #fff;
    border: 1.5px solid var(--accent-soft);
    border-radius: 22px;
    padding: 26px 22px 24px;
    box-shadow: var(--shadow);
  }
  .promo-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--accent-soft);
    color: var(--accent-deep);
    font-size: 12.5px;
    font-weight: 700;
    padding: 7px 13px;
    border-radius: 999px;
  }
  .promo-tag b { font-weight: 800; letter-spacing: 0.02em; }
  .promo-price { margin: 20px 0 4px; line-height: 1; }
