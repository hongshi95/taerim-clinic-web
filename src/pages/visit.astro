---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Header from '~/components/layout/Header.astro';
import Footer from '~/components/layout/Footer.astro';
import { SITE, CLINIC } from '~/consts';

const title = '오시는길 - 진료시간·주차·전화';
const description = `${CLINIC.legalName} 위치, 진료시간, 주차, 전화번호 안내. ${CLINIC.address.addressLocality}.`;
---

<BaseLayout title={title} description={description} type="website" canonicalPath="/visit/">
  <Header />

  {/* 오시는길 hero - 좌측 정보 + 우측 지도 (오시는길 페이지 목적과 직접 정렬) */}
  <section class="bg-stone-50 border-b border-stone-200">
    <div class="v-container py-10 md:py-14 lg:py-16 grid lg:grid-cols-[1fr_1.15fr] gap-8 lg:gap-12 items-stretch">
      {/* 좌측: 텍스트 + 듀얼 길찾기 */}
      <div class="flex flex-col justify-center">
        <div class="text-[13px] md:text-sm font-bold tracking-[0.2em] uppercase text-green-900 mb-3">
          태림한의원 · {CLINIC.address.addressLocality}
        </div>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-stone-900 tracking-tight leading-[1.2]">
          오시는길
        </h1>
        <p class="mt-4 text-lg md:text-xl text-stone-700 leading-[1.6]">
          {CLINIC.address.addressLocality} {CLINIC.address.streetAddress || '(상세 주소 준비 중)'}
        </p>
        {CLINIC.phone && (
          <p class="mt-2 text-stone-600">
            <a href={`tel:${CLINIC.phone}`} class="text-green-800 font-bold text-lg md:text-xl hover:underline tabular-nums">{CLINIC.phone}</a>
          </p>
        )}

        {/* 듀얼 길찾기 + 예약 - 네이버 지도(naverMapUrl) vs 네이버 플레이스(naverPlaceUrl) 분리 */}
        <div class="mt-6 flex flex-wrap gap-2.5">
          {CLINIC.naverMapUrl && (
            <a
              href={CLINIC.naverMapUrl}
              target="_blank"
              rel="noopener"
              style="color:#ffffff;background-color:#15803d;"
              class="inline-flex items-center gap-2 px-5 py-3 rounded-full text-[15px] md:text-base font-bold hover:bg-green-900 shadow-lg shadow-green-900/20"
            >
              <svg aria-hidden="true" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              네이버 지도·길찾기
              <span aria-hidden="true">→</span>
            </a>
          )}
          <a
            href={`https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(`${CLINIC.address.addressLocality} ${CLINIC.address.streetAddress}`)}&destination_place_id=${CLINIC.googleMapsCid}`}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-5 py-3 rounded-full bg-white text-stone-700 text-[15px] md:text-base font-bold border border-stone-300 hover:bg-stone-100"
          >
            <svg aria-hidden="true" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><line x1="9" x2="9" y1="3" y2="18"/><line x1="15" x2="15" y1="6" y2="21"/></svg>
            Google 길찾기
            <span aria-hidden="true">→</span>
          </a>
          {CLINIC.naverPlaceUrl && (
            <a
              href={CLINIC.naverPlaceUrl}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 px-5 py-3 rounded-full bg-white text-green-900 text-[15px] md:text-base font-bold border border-green-300 hover:bg-green-50"
            >
              <svg aria-hidden="true" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
              네이버 플레이스 예약
              <span aria-hidden="true">→</span>
            </a>
          )}
        </div>
      </div>

      {/* 우측: Google Maps 임베드 (CID 기반 - 비즈니스 listing 정확 매칭, 좌표보다 신뢰도 ↑) */}
      <div class="relative w-full h-[260px] sm:h-[320px] lg:h-full lg:min-h-[360px] rounded-2xl overflow-hidden ring-1 ring-stone-200 shadow-md shadow-stone-900/10">
        <iframe
          title={`${CLINIC.legalName} 위치 지도`}
          src={`https://maps.google.com/maps?cid=${CLINIC.googleMapsCid}&output=embed&hl=ko`}
          width="100%"
          height="100%"
          style="border:0;"
          loading="eager"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <main class="v-container py-12 md:py-16">
    <div class="grid gap-6 md:grid-cols-2">
      {/* 주소·연락처 카드 - 시니어 친화 */}
      <section class="rounded-2xl bg-green-50/40 ring-1 ring-green-200/60 p-6 md:p-8">
        <h2 class="text-xl md:text-2xl font-bold text-green-950 mb-6 flex items-center gap-2">
          <svg aria-hidden="true" class="w-5 h-5 text-green-800" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          위치 & 연락처
        </h2>
        <dl class="space-y-5 text-[17px] md:text-lg">
          <div>
            <dt class="text-sm md:text-base font-bold text-stone-500 uppercase tracking-wide mb-1">주소</dt>
            <dd class="text-stone-900 font-medium leading-[1.6]">
              {CLINIC.address.addressLocality} {CLINIC.address.streetAddress || '(준비 중)'}
            </dd>
          </div>
          <div>
            <dt class="text-sm md:text-base font-bold text-stone-500 uppercase tracking-wide mb-1">전화</dt>
            <dd>
              {CLINIC.phone ? (
                <a href={`tel:${CLINIC.phone}`} class="text-green-800 font-bold text-xl md:text-2xl hover:underline tabular-nums">{CLINIC.phone}</a>
              ) : (
                <span class="text-stone-400">준비 중</span>
              )}
            </dd>
          </div>
          <div>
            <dt class="text-sm md:text-base font-bold text-stone-500 uppercase tracking-wide mb-2">예약·상담 · SNS</dt>
            <dd class="flex flex-wrap gap-2">
              {CLINIC.naverPlaceUrl && (
                <a href={CLINIC.naverPlaceUrl} target="_blank" rel="noopener" style="color:#ffffff;background-color:#15803d;" class="inline-flex items-center gap-1.5 px-4 py-2.5 rounded-full text-base font-bold hover:bg-green-900">
                  네이버 플레이스 →
                </a>
              )}
              {CLINIC.kakaoChannelUrl && (
                <a href={CLINIC.kakaoChannelUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 px-4 py-2.5 rounded-full bg-yellow-400 text-yellow-900 text-base font-bold hover:bg-yellow-500">
                  카카오 채널 →
                </a>
              )}
              {CLINIC.blogUrl && (
                <a href={CLINIC.blogUrl} target="_blank" rel="noopener" style="color:#ffffff;background-color:#16a34a;" class="inline-flex items-center gap-1.5 px-4 py-2.5 rounded-full text-base font-bold hover:bg-green-700">
                  네이버 블로그 →
                </a>
              )}
              {CLINIC.instagramUrl && (
                <a href={CLINIC.instagramUrl} target="_blank" rel="noopener" style="color:#ffffff;background-image:linear-gradient(135deg,#d946ef,#16a34a);" class="inline-flex items-center gap-1.5 px-4 py-2.5 rounded-full text-base font-bold hover:opacity-90">
                  인스타그램 →
                </a>
              )}
              {CLINIC.threadsUrl && (
                <a href={CLINIC.threadsUrl} target="_blank" rel="noopener" style="color:#ffffff;background-color:#000000;" class="inline-flex items-center gap-1.5 px-4 py-2.5 rounded-full text-base font-bold hover:bg-stone-800">
                  스레드 →
                </a>
              )}
            </dd>
          </div>
        </dl>
      </section>

      {/* 진료시간 카드 - 시니어 친화 */}
      <section class="rounded-2xl bg-stone-50 ring-1 ring-stone-200 p-6 md:p-8">
        <h2 class="text-xl md:text-2xl font-bold text-stone-800 mb-6 flex items-center gap-2">
          <svg aria-hidden="true" class="w-5 h-5 text-green-800" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          진료시간
        </h2>
        <dl class="space-y-3 text-[17px] md:text-lg">
          <div class="flex justify-between border-b border-stone-200 pb-3">
            <dt class="font-bold text-stone-700">월·수</dt>
            <dd class="text-stone-900 font-medium tabular-nums">09:00 - 20:00</dd>
          </div>
          <div class="flex justify-between border-b border-stone-200 pb-3">
            <dt class="font-bold text-stone-700">화·목·금</dt>
            <dd class="text-stone-900 font-medium tabular-nums">09:00 - 18:30</dd>
          </div>
          <div class="flex justify-between border-b border-stone-200 pb-3">
            <dt class="font-bold text-stone-700">토요일</dt>
            <dd class="text-stone-900 font-medium tabular-nums">09:00 - 14:00</dd>
          </div>
          <div class="flex justify-between border-b border-stone-200 pb-3">
            <dt class="font-bold text-stone-700">일요일</dt>
            <dd class="text-stone-400">휴진 (공휴일 09:00 - 14:00)</dd>
          </div>
          <div class="flex justify-between pt-1">
            <dt class="font-bold text-stone-700">점심시간</dt>
            <dd class="text-stone-600 text-base tabular-nums">13:00 - 14:00</dd>
          </div>
        </dl>
        <p class="mt-5 text-sm md:text-base text-stone-500 leading-relaxed">
          공휴일·임시 휴진은 네이버 플레이스에서 최신 정보를 확인해주세요.
        </p>
      </section>
    </div>

    {/* 교통·주차 안내 - 시니어 친화 */}
    <section class="mt-8 rounded-2xl bg-white ring-1 ring-stone-200 p-6 md:p-8">
      <h2 class="text-xl md:text-2xl font-bold text-stone-900 mb-6">
        교통·주차
      </h2>
      <ul class="space-y-4 text-[17px] md:text-lg text-stone-800 leading-[1.7]">
        <li><strong class="text-green-900">위치</strong> · 이마트 월배점 맞은편, 진천로 93 애플플라자 3층 (대구 달서구 대천동)</li>
        <li><strong class="text-green-900">자가용·주차</strong> · 진료시간 중 무료주차. 평일은 상가 주차장(층수 무관), 휴무일에는 월배 이마트 야외 주차장을 이용하실 수 있습니다.</li>
        <li><strong class="text-green-900">지하철·버스</strong> · 대구 도시철도 1호선 진천역 인근, 월배 이마트 일대 정류장 이용</li>
      </ul>
    </section>

  </main>

  <Footer />
</BaseLayout>
