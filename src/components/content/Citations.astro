---
// 출처 표시 (E-E-A-T) — 본문 하단에 렌더링

interface Citation {
  claim: string;
  source: string;
  url?: string;
}

interface Props {
  citations: Citation[];
}

const { citations } = Astro.props;
---

{citations.length > 0 && (
  <section class="not-prose my-10 p-5 rounded-xl bg-gray-50 border border-gray-200" aria-labelledby="citations-heading">
    <h2 id="citations-heading" class="text-sm font-bold text-gray-600 uppercase tracking-wider mb-4">
      출처 및 인용
    </h2>
    <ol class="space-y-3 text-sm text-gray-700">
      {citations.map((c, i) => (
        <li class="flex gap-3">
          <span class="shrink-0 font-mono text-xs text-gray-500 pt-0.5">[{i + 1}]</span>
          <div class="flex-1">
            <p class="text-gray-700 leading-relaxed m-0">{c.claim}</p>
            <p class="mt-1 text-xs text-gray-500 m-0">
              출처:{' '}
              {c.url ? (
                <a href={c.url} rel="nofollow noopener" target="_blank" class="underline hover:text-deok-600">
                  {c.source}
                </a>
              ) : (
                <span>{c.source}</span>
              )}
            </p>
          </div>
        </li>
      ))}
    </ol>
  </section>
)}
