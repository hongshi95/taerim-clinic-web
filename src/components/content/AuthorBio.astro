---
// 저자 바이오 카드 — E-E-A-T 시그널
// GEO 인용 확률 4.8배 상승에 기여

interface Props {
  slug: string;
  name: string;
  bio: string;
  avatarUrl?: string;
  expertise?: string[];
}

const { slug, name, bio, avatarUrl, expertise } = Astro.props;
---

<aside class="not-prose my-10 p-6 rounded-2xl border border-gray-200 bg-gray-50">
  <div class="flex items-start gap-4">
    {avatarUrl ? (
      <img
        src={avatarUrl}
        alt={`${name} 프로필 이미지`}
        class="w-14 h-14 rounded-full object-cover shrink-0"
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="w-14 h-14 rounded-full bg-deok-100 shrink-0 flex items-center justify-center text-deok-700 font-bold text-lg">
        {name.charAt(0)}
      </div>
    )}

    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-1">
        <a
          href={`/about/author/${slug}`}
          rel="author"
          class="font-bold text-gray-900 hover:text-deok-700"
        >
          {name}
        </a>
      </div>
      <p class="text-sm text-gray-600 leading-relaxed m-0">{bio}</p>
      {expertise && expertise.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-1.5">
          {expertise.map((tag) => (
            <span class="px-2 py-0.5 text-xs rounded-md bg-white border border-gray-200 text-gray-700">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>
  </div>
</aside>
