---
import FAQSchema from '~/components/seo/FAQSchema.astro';

interface FAQ {
  q: string;
  a: string;
}

interface Props {
  faqs: FAQ[];
  title?: string;
}

const { faqs, title = '자주 묻는 질문' } = Astro.props;
---

{faqs.length > 0 && (
  <>
    <FAQSchema faqs={faqs} />

    <section class="not-prose my-12" aria-labelledby="faq-heading">
      <h2 id="faq-heading" class="text-2xl font-bold text-gray-900 mb-6 pb-2 border-b-2 border-deok-200">
        {title}
      </h2>

      <div class="space-y-3">
        {faqs.map((item, i) => (
          <details class="group rounded-xl border border-gray-200 bg-white overflow-hidden transition-colors hover:border-deok-300">
            <summary class="flex items-start gap-3 p-5 cursor-pointer list-none select-none">
              <span class="inline-flex items-center justify-center w-7 h-7 shrink-0 rounded-full bg-deok-100 text-deok-700 text-sm font-bold">
                Q
              </span>
              <h3 class="flex-1 font-semibold text-gray-900 leading-snug m-0">
                {item.q}
              </h3>
              <span class="text-gray-400 group-open:rotate-180 transition-transform shrink-0" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </span>
            </summary>
            <div class="px-5 pb-5 pl-[60px]">
              <p class="text-[15px] text-gray-700 leading-[1.75] m-0 whitespace-pre-line">
                {item.a}
              </p>
            </div>
          </details>
        ))}
      </div>
    </section>
  </>
)}
