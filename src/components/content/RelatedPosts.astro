---
/**
 * RelatedPosts.astro
 *
 * 글 본문 아래(FAQ 다음)에 "다음에 읽을 글" 카드 3개 렌더.
 *
 * Props:
 *   posts: Array<{ url, title, summary?, cat? }>
 *
 * 출처: vivid-blog scripts/templates/RelatedPosts.astro
 * 마지막 갱신: 2026-05-19 (W1 내부 링크 인프라)
 */
interface RelatedPost {
  url: string;
  title: string;
  summary?: string;
  cat?: string;
}

interface Props {
  posts: RelatedPost[];
  heading?: string;
}

const { posts, heading = '다음에 읽을 글' } = Astro.props;
const hasPosts = Array.isArray(posts) && posts.length > 0;
---

{hasPosts && (
  <aside class="not-prose v-related-block mt-12 mb-8">
    <div class="v-related-header flex items-center gap-3 mb-4">
      <span class="text-sm font-bold tracking-wider text-deok-700 uppercase">{heading}</span>
      <div class="v-related-line flex-1 h-px bg-gradient-to-r from-gray-200 to-transparent"></div>
    </div>
    <div class="v-related-grid grid grid-cols-1 md:grid-cols-3 gap-4">
      {posts.map((p) => (
        <a
          href={p.url}
          class="v-related-card group block p-4 rounded-xl border border-gray-200 hover:border-deok-300 hover:shadow-md transition-all bg-white"
        >
          {p.cat && (
            <div class="v-related-cat text-xs font-semibold text-deok-600 mb-2 uppercase tracking-wide">
              {p.cat}
            </div>
          )}
          <div class="v-related-title font-bold text-gray-900 mb-2 group-hover:text-deok-700 line-clamp-2 leading-snug">
            {p.title}
          </div>
          {p.summary && (
            <div class="v-related-desc text-sm text-gray-600 line-clamp-3 leading-relaxed">
              {p.summary}
            </div>
          )}
        </a>
      ))}
    </div>
  </aside>
)}
