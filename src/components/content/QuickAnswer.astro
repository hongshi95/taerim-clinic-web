---
// 빠른 답 박스 - AEO/GEO 핵심 컴포넌트
// 첫 문단 직답 + 핵심 요약 (AI 인용의 발췌 대상)

interface Props {
  summary: string;
  bullets?: string[];
}

const { summary, bullets } = Astro.props;
---

<aside
  class="not-prose my-8 p-6 rounded-2xl border border-deok-200 bg-gradient-to-br from-deok-50 to-white"
  role="complementary"
  aria-label="빠른 답"
>
  <header class="flex items-center gap-2 mb-3">
    <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-deok-600 text-white text-xs font-bold">
      !
    </span>
    <h2 class="text-sm font-bold text-deok-900 uppercase tracking-wider m-0">빠른 답</h2>
  </header>

  <p class="text-[16px] leading-[1.75] text-gray-800 font-medium m-0">
    {summary}
  </p>

  {bullets && bullets.length > 0 && (
    <ul class="mt-4 space-y-2 text-[15px] text-gray-700">
      {bullets.map((b) => (
        <li class="flex gap-2">
          <span class="text-deok-500 shrink-0" aria-hidden="true">•</span>
          <span>{b}</span>
        </li>
      ))}
    </ul>
  )}
</aside>
