---
// 진료시간 + 위치 + CTA를 한 번에 보여주는 strip (홈에 hero 직후 노출)
// 환자가 첫 화면에서 "지금 가도 되나" 즉시 판단할 수 있게 설계
import { CLINIC } from '~/consts';
---

<section class="bg-white border-b border-stone-200/60" aria-label="진료시간과 위치 안내">
  <div class="v-container py-6 md:py-8">
    <div class="grid gap-6 md:gap-8 md:grid-cols-3 items-center">
      {/* 진료시간 (가장 시급한 정보) */}
      <div class="flex items-start gap-3" data-reveal>
        <span aria-hidden="true" class="mt-1 inline-flex items-center justify-center w-10 h-10 rounded-full bg-green-50 text-green-800 shrink-0">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </span>
        <div class="text-[14px] md:text-[15px] leading-[1.7]">
          <div class="font-bold text-stone-900 mb-0.5">진료시간</div>
          <div class="text-stone-700 tabular-nums">
            월·수 09:00 - 20:00 (야간진료)<br />
            화·목·금 09:00 - 18:30<br />
            토 09:00 - 14:00 · 점심 13:00 - 14:00<br />
            <span class="text-stone-400">일요일 휴진 · 공휴일 09:00 - 14:00</span>
          </div>
        </div>
      </div>

      {/* 위치 */}
      <div class="flex items-start gap-3" data-reveal data-reveal-delay="2">
        <span aria-hidden="true" class="mt-1 inline-flex items-center justify-center w-10 h-10 rounded-full bg-green-50 text-green-800 shrink-0">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
        </span>
        <div class="text-[14px] md:text-[15px] leading-[1.7]">
          <div class="font-bold text-stone-900 mb-0.5">위치</div>
          <div class="text-stone-700">
            대구 달서구 진천로 93<br />
            애플플라자 3층<br />
            <span class="text-stone-500 text-[13px]">대구도시철도 1호선 진천역 4번 출구 도보 6분 (399m)</span>
          </div>
        </div>
      </div>

      {/* CTA */}
      <div class="flex flex-col gap-2.5" data-reveal data-reveal-delay="3">
        {CLINIC.naverPlaceUrl && (
          <a
            href={CLINIC.naverPlaceUrl}
            target="_blank"
            rel="noopener"
            style="background-color:#15803d;color:#ffffff;"
            class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-full text-[15px] font-bold hover:bg-green-900 shadow-lg shadow-green-900/15 transition-colors"
          >
            네이버 플레이스에서 예약
            <span aria-hidden="true">→</span>
          </a>
        )}
        {CLINIC.phone && (
          <a
            href={`tel:${CLINIC.phone}`}
            class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-full bg-white text-green-900 text-[15px] font-bold border border-green-200 hover:bg-green-50 tabular-nums"
          >
            <svg aria-hidden="true" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
            </svg>
            {CLINIC.phone}
          </a>
        )}
      </div>
    </div>

    {/* 임시 휴진 안내 (네이버 플레이스 fallback) */}
    <p class="mt-4 md:mt-5 text-xs text-stone-500 text-center leading-relaxed">
      공휴일·임시 휴진·점심시간은 네이버 플레이스에서 최신 정보를 확인해주세요.
    </p>
  </div>
</section>
