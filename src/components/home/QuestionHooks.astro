---
// 카테고리별 대표 질문 3개 - 숫자 지표 대신 "내가 궁금했던 것" 후킹
import type { CollectionEntry } from 'astro:content';

interface Hook {
  category: CollectionEntry<'categories'>;
  post: CollectionEntry<'posts'>;
  q: string;
  a: string;
}

interface Props {
  hooks: Hook[];
}
const { hooks } = Astro.props;

const slugOf = (p: CollectionEntry<'posts'>) =>
  p.id.replace(/\.mdx?$/, '').split('/').pop();
---

{hooks.length > 0 && (
  <section id="quick-answers" class="v-container py-14 md:py-20 scroll-mt-20">
    <div class="mb-8 md:mb-10 text-center">
      <p class="text-xs md:text-sm font-semibold text-deok-600 tracking-wide mb-2">자주 받는 질문</p>
      <h2 class="text-2xl md:text-4xl font-bold text-gray-900 tracking-tight">
        가장 많이 찾으신 답 - <span class="text-deok-600">한 줄 요약</span>
      </h2>
      <p class="mt-3 text-sm md:text-base text-gray-600">
        막막했던 한 가지부터, 본문은 단계별 절차로 이어집니다.
      </p>
    </div>

    <div class="grid gap-4 md:gap-5 md:grid-cols-3">
      {hooks.map(({ category, post, q, a }) => {
        const slug = slugOf(post);
        return (
          <a
            href={`/${post.data.category}/${slug}/`}
            class="group relative flex flex-col rounded-2xl border border-gray-200 bg-white p-5 md:p-6 transition-all hover:border-deok-300 hover:shadow-lg hover:-translate-y-0.5"
          >
            <div class="flex items-center gap-1.5 mb-3">
              <span class="text-[10px] font-semibold text-gray-500 tracking-[0.2em] uppercase">
                {category.data.name}
              </span>
            </div>

            {/* 질문 */}
            <div class="flex items-start gap-2 mb-3">
              <span class="shrink-0 mt-0.5 inline-flex items-center justify-center w-5 h-5 rounded-full bg-deok-100 text-deok-700 text-[10px] font-bold">
                Q
              </span>
              <h3 class="text-sm md:text-[15px] font-bold text-gray-900 leading-snug group-hover:text-deok-700 transition-colors line-clamp-2">
                {q}
              </h3>
            </div>

            {/* 답 티저 */}
            <div class="flex items-start gap-2 mb-4">
              <span class="shrink-0 mt-0.5 inline-flex items-center justify-center w-5 h-5 rounded-full bg-green-100 text-green-800 text-[10px] font-bold">
                A
              </span>
              <p class="text-xs md:text-sm text-gray-600 leading-relaxed line-clamp-3">
                {a}
              </p>
            </div>

            <div class="mt-auto pt-3 border-t border-gray-100 flex items-center justify-between">
              <span class="text-[11px] text-gray-400 line-clamp-1">
                출처 - {post.data.title}
              </span>
              <span class="shrink-0 text-xs font-semibold text-deok-600 group-hover:translate-x-0.5 transition-transform">
                전문 →
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </section>
)}
