---
// 카테고리별 큐레이션 - 대표 글(featured) 1개 + 최신 글 2개
import type { CollectionEntry } from 'astro:content';

interface Props {
  categories: CollectionEntry<'categories'>[];
  postsByCategory: Record<string, CollectionEntry<'posts'>[]>;
}
const { categories, postsByCategory } = Astro.props;

const fmtDate = (d: Date) =>
  d.toLocaleDateString('ko-KR', { month: 'long', day: 'numeric' });
const slugOf = (p: CollectionEntry<'posts'>) =>
  p.id.replace(/\.mdx?$/, '').split('/').pop();
---

<section class="py-16 md:py-20 bg-gradient-to-b from-white via-green-50/40 to-green-50/30 relative overflow-hidden">
  {/* 옅은 노을 분위기 - hero와 일관성 */}
  <div aria-hidden="true" class="absolute inset-0 -z-10 overflow-hidden">
    <div class="absolute -left-20 top-1/4 w-[400px] h-[400px] rounded-full bg-gradient-to-br from-green-200/20 to-transparent blur-3xl"></div>
    <div class="absolute right-0 bottom-0 w-[500px] h-[500px] rounded-full bg-gradient-to-tl from-green-200/20 to-transparent blur-3xl"></div>
  </div>

  <div class="v-container relative">
    <div class="flex items-end justify-between mb-8">
      <div>
        <div class="inline-block px-3 py-1 rounded-full bg-deok-100/80 text-deok-700 text-[11px] font-bold tracking-wide mb-2">
          GUIDE
        </div>
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900">
          진료과목별 건강 정보
        </h2>
      </div>
      <a href="/posts/" class="text-sm font-medium text-deok-600 hover:text-deok-700 hidden md:inline">
        전체 보기 →
      </a>
    </div>

    <div class="space-y-12 md:space-y-14">
      {categories.map((cat) => {
        const posts = postsByCategory[cat.id] ?? [];
        const hero = posts.find((p) => p.data.featured) ?? posts[0];
        const rest = posts.filter((p) => p !== hero).slice(0, 2);
        if (!hero) return null;
        const heroSlug = slugOf(hero);
        const hasCover = !!hero.data.coverImage;
        return (
          <div>
            {/* 카테고리 헤더 */}
            <header class="flex items-center justify-between mb-5 pb-3 border-b border-green-200/40">
              <div class="flex items-center gap-3">
                <span
                  class="text-xs font-bold tracking-[0.2em] text-deok-700 tabular-nums"
                  aria-hidden="true"
                  style="font-family: var(--font-display);"
                >
                  {String((cat.data.order ?? 0)).padStart(2, '0')}
                </span>
                <div>
                  <h3 class="text-lg md:text-xl font-bold text-gray-900">{cat.data.name}</h3>
                  <p class="text-xs text-gray-500 line-clamp-1">{cat.data.description}</p>
                </div>
              </div>
              <a
                href={`/${cat.id}/`}
                class="text-xs md:text-sm text-gray-500 hover:text-deok-600 font-medium whitespace-nowrap"
              >
                전체 {posts.length}편 →
              </a>
            </header>

            <div class="grid gap-5 md:grid-cols-[1.4fr_1fr]">
              {/* 대표 글 (큰 카드) - cover 유무에 따라 톤 분기 */}
              <a
                href={`/${hero.data.category}/${heroSlug}/`}
                class:list={[
                  "group relative block rounded-2xl overflow-hidden aspect-[16/10] md:aspect-auto md:min-h-[240px] shadow-lg shadow-green-200/40 transition-all hover:shadow-xl hover:shadow-green-300/40 hover:-translate-y-0.5",
                  hasCover
                    ? "bg-gradient-to-br from-green-500 via-green-500 to-deok-700 text-white"
                    : "bg-gradient-to-br from-green-100 via-green-100 to-green-100 text-gray-900 ring-1 ring-green-200/60"
                ]}
              >
                {hasCover && (
                  <>
                    <img
                      src={hero.data.coverImage}
                      alt={hero.data.coverImageAlt ?? hero.data.title}
                      class="absolute inset-0 w-full h-full object-cover opacity-70 group-hover:opacity-80 group-hover:scale-105 transition-all duration-700"
                      loading="lazy"
                      decoding="async"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/65 via-black/15 to-transparent"></div>
                  </>
                )}

                {/* cover 없을 때 - 카테고리 영문명 + 번호로 시각 임팩트 (이모지 대신 타이포 기반) */}
                {!hasCover && (
                  <div
                    aria-hidden="true"
                    class="absolute -right-4 -bottom-8 text-[120px] md:text-[160px] leading-none font-bold tracking-tighter opacity-10 select-none pointer-events-none text-deok-800"
                    style="font-family: var(--font-display);"
                  >
                    {String((cat.data.order ?? 0)).padStart(2, '0')}
                  </div>
                )}

                <div class="absolute inset-0 p-5 md:p-6 flex flex-col justify-end">
                  {hero.data.featured && (
                    <span class:list={[
                      "self-start inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[10px] font-bold mb-2",
                      hasCover
                        ? "bg-green-400/95 text-green-950"
                        : "bg-deok-600 text-white shadow-sm"
                    ]}>
                      FEATURED
                    </span>
                  )}
                  <h4 class:list={[
                    "text-lg md:text-xl font-bold leading-snug line-clamp-2",
                    hasCover ? "text-white drop-shadow-md" : "text-gray-900"
                  ]}>
                    {hero.data.title}
                  </h4>
                  {hero.data.quickAnswerBullets && hero.data.quickAnswerBullets.length > 0 && (
                    <p class:list={[
                      "mt-2 text-xs md:text-sm line-clamp-1",
                      hasCover ? "text-white/90" : "text-gray-700"
                    ]}>
                      ✓ {hero.data.quickAnswerBullets[0]}
                    </p>
                  )}
                </div>
              </a>

              {/* 최신 글 2개 (또는 placeholder) */}
              <div class="flex flex-col gap-3">
                {rest.length === 0 && (
                  <div class="h-full rounded-2xl border border-dashed border-green-200/60 bg-white/70 backdrop-blur-sm p-5 text-center text-xs text-gray-400 flex items-center justify-center">
                    곧 새 글이 추가됩니다
                  </div>
                )}
                {rest.map((p) => {
                  const s = slugOf(p);
                  return (
                    <a
                      href={`/${p.data.category}/${s}/`}
                      class="group block rounded-xl border border-green-200/40 bg-white/80 backdrop-blur-sm p-4 transition-all hover:border-deok-300 hover:bg-white hover:shadow-md"
                    >
                      <h4 class="text-sm font-bold text-gray-900 leading-snug group-hover:text-deok-700 line-clamp-2">
                        {p.data.title}
                      </h4>
                      <p class="mt-1.5 text-xs text-gray-500 line-clamp-2 leading-relaxed">
                        {p.data.description}
                      </p>
                      <time class="mt-2 block text-[10px] text-gray-400" datetime={p.data.publishedAt.toISOString()}>
                        {fmtDate(p.data.publishedAt)}
                      </time>
                    </a>
                  );
                })}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
