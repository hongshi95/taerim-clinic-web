---
// 한의원 둘러보기 + 연혁 (이력) - 신뢰감 강화
import { CLINIC } from '~/consts';

// timeline - 환자 관점 (내부 서사가 아니라 환자가 얻는 것 중심)
const timeline = [
  {
    year: '2023',
    month: '',
    title: '충분히 듣는 진료로 시작했습니다',
    body: `${CLINIC.address.addressLocality} 대천동에서 문을 열었습니다. 통증을 빨리 누르기보다, 왜 아픈지를 충분히 듣고 찾는 진료를 처음부터 원칙으로 삼았습니다.`,
  },
  {
    year: '2024',
    month: '',
    title: '다시 찾아주시는 분들이 늘었습니다',
    body: '한 번 오신 분이 두 번, 세 번 다시 찾아주시기 시작했습니다. 통증이 줄고 일상이 편해진 분들의 재방문이, 저희에게는 가장 정직한 평가입니다.',
  },
  {
    year: '현재',
    month: '',
    title: '환자분을 위해 계속 배웁니다',
    body: '쉬는 일요일에도 서울에서 새로운 치료법을 배웁니다. 오늘보다 다음 진료가 나아야, 환자분이 더 빨리 회복하실 수 있기 때문입니다.',
  },
];

const facilities = [
  {
    image: '/images/clinic/clinic-lobby.webp',
    alt: '태림한의원 메인 홀 - 접수 데스크와 太林 로고, 약재 진열장',
    label: '접수·대기',
    title: '환자분을 맞이하는 메인 홀',
  },
  {
    image: '/images/clinic/clinic-interior.webp',
    alt: '태림한의원 진료실 - 원장이 견인 치료를 진행하는 모습',
    label: '진료실',
    title: '원장이 직접 진료하는 공간',
  },
  {
    image: '/images/clinic/treatment-room.png',
    alt: '태림한의원 치료실 (적외선 물리치료기 + 베드)',
    label: '치료실',
    title: '물리치료·찜질 치료실',
  },
  {
    image: '/images/clinic/shockwave-machine.webp',
    alt: '태림한의원 근건이완수기요법에 쓰는 체외충격파 기기',
    label: '신규 도입',
    title: '근건이완수기요법 장비 (체외충격파)',
  },
  {
    image: '/images/clinic/place-02.png',
    alt: '태림한의원 한약 추출 시설 - 가운 입은 원장이 한약을 달이는 모습',
    label: '한약 제조',
    title: '직접 달이는 체질별 맞춤 한약',
  },
];
---

<section class="bg-white py-12 sm:py-16 md:py-24 border-b border-stone-100">
  <div class="v-container">
    {/* 1. 한의원 둘러보기 - 사진 3장 grid */}
    <header class="mb-10">
      <div class="text-[11px] font-bold tracking-[0.25em] uppercase text-green-900 mb-4">
        한의원 둘러보기
      </div>
      <h2 class="text-[1.7rem] sm:text-3xl md:text-4xl font-bold text-stone-900 tracking-tight leading-[1.2]">
        환자분이 만나게 될 <span class="font-serif italic text-green-900">한의원의 모습</span>
      </h2>
    </header>

    <div class="grid gap-4 md:gap-6 sm:grid-cols-2 lg:grid-cols-5 mb-16 md:mb-24">
      {facilities.map((f) => (
        <figure class="group">
          <div class="aspect-[4/3] overflow-hidden rounded-sm bg-stone-100 shadow-md shadow-stone-900/10">
            <img
              src={f.image}
              alt={f.alt}
              class="w-full h-full object-cover object-center group-hover:scale-[1.02] transition-transform duration-500"
              loading="lazy"
              decoding="async"
              width="600"
              height="450"
            />
          </div>
          <figcaption class="mt-4">
            <div class="text-[10px] font-bold tracking-[0.25em] uppercase text-green-900 mb-1.5">
              {f.label}
            </div>
            <div class="text-base font-bold text-stone-900 tracking-tight">
              {f.title}
            </div>
          </figcaption>
        </figure>
      ))}
    </div>

    {/* 2. 연혁 timeline */}
    <header class="mb-10">
      <div class="text-[11px] font-bold tracking-[0.25em] uppercase text-green-900 mb-4">
        연혁
      </div>
      <h2 class="text-[1.7rem] sm:text-3xl md:text-4xl font-bold text-stone-900 tracking-tight leading-[1.2]">
        걸어온 길, <span class="font-serif italic text-green-900 mr-2">향하는 곳</span>
      </h2>
    </header>

    <ol class="relative border-l-2 border-stone-200 pl-8 md:pl-10 space-y-10 max-w-3xl">
      {timeline.map((t) => (
        <li class="relative">
          <span aria-hidden="true" class="absolute -left-[37px] md:-left-[45px] top-1.5 w-3.5 h-3.5 rounded-full bg-green-800 ring-4 ring-white"></span>
          <div class="flex items-baseline gap-3 mb-2">
            <span class="text-green-900 font-bold tabular-nums text-xl tracking-tight">
              {t.year}
            </span>
            {t.month && (
              <span class="text-xs text-stone-500 tracking-wide">{t.month}</span>
            )}
          </div>
          <h3 class="text-lg md:text-xl font-bold text-stone-900 tracking-tight">
            {t.title}
          </h3>
          <p class="mt-2 text-[17px] text-stone-700 leading-[1.85] max-w-2xl">
            {t.body}
          </p>
        </li>
      ))}
    </ol>
  </div>
</section>
