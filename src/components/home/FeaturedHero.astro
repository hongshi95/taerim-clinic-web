---
// 대표 글 - 풀 콘텐츠 카드 (좌측 빈 그라데이션 영역 제거, 콘텐츠가 메인)
// 전환·체류 최적화: Quick Answer 풀 노출 + 출처 + 읽기 시간 + 강한 CTA
import type { CollectionEntry } from 'astro:content';
import { getEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}
const { post } = Astro.props;
const category = await getEntry('categories', post.data.category);
const slug = post.id.replace(/\.mdx?$/, '').split('/').pop();
const href = `/${post.data.category}/${slug}/`;
const bullets = post.data.quickAnswerBullets ?? [];
const hasCover = Boolean(post.data.coverImage);

// 출처 (신뢰 신호) - 첫 1~2개 source 표시
const citations = post.data.citations ?? [];
const sourceLabel = citations.length > 0
  ? Array.from(new Set(citations.slice(0, 3).map(c => c.source))).slice(0, 2).join(' · ')
  : null;

// 읽기 시간 추정 (한국어 평균 분당 600자, body 없으면 description으로 fallback)
const bodyLen =
  (typeof post.body === 'string' ? post.body.length : 0) ||
  (post.data.description?.length ?? 0) * 12;
const readMinutes = Math.max(2, Math.round(bodyLen / 600));
---

<section class="v-container pt-4 pb-12 md:pb-16">
  {/* 상단 메타 띠 - 대표 + 읽기시간 + 날짜 */}
  <div class="mb-5 flex items-center gap-3 flex-wrap">
    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-green-50 text-green-900 text-xs font-bold ring-1 ring-green-300/70 shadow-sm">
      <span aria-hidden="true" class="inline-block w-1.5 h-1.5 rounded-full bg-green-700"></span>
      원장이 정리한 건강 정보
    </span>
    <span class="text-xs text-gray-500 flex items-center gap-1.5">
      <svg aria-hidden="true" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      {readMinutes}분 읽기
    </span>
    <time class="text-xs text-gray-400 flex items-center gap-1.5" datetime={post.data.publishedAt.toISOString()}>
      <span aria-hidden="true">📅</span>
      {post.data.publishedAt.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
    </time>
  </div>

  <a
    href={href}
    class="group block rounded-3xl border border-gray-200 bg-white overflow-hidden transition-all hover:border-deok-300 hover:shadow-2xl hover:-translate-y-0.5"
  >
    {/* cover image 있을 때만 상단 좁은 띠 (높이 제한, 절반 차지 X) */}
    {hasCover && (
      <div class="relative h-48 md:h-56 overflow-hidden">
        <img
          src={post.data.coverImage}
          alt={post.data.coverImageAlt ?? post.data.title}
          class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700"
          loading="eager"
          decoding="async"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
      </div>
    )}

    <div class="p-6 md:p-8 lg:p-10">
      {/* 카테고리 칩 */}
      {category && (
        <div class="mb-4">
          <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-deok-50 text-deok-700 text-xs font-semibold ring-1 ring-deok-200">
            {category.data.name}
          </span>
        </div>
      )}

      {/* 제목 - 큼직, 가독성 */}
      <h2 class="text-2xl md:text-3xl lg:text-4xl font-bold text-gray-900 leading-tight group-hover:text-deok-700 transition-colors tracking-tight">
        {post.data.title}
      </h2>

      {/* 설명 */}
      <p class="mt-4 text-sm md:text-base text-gray-600 leading-relaxed">
        {post.data.description}
      </p>

      {/* Quick Answer 박스 - 4개 풀 노출 (체류 ↑, 전환 ↑) */}
      {bullets.length > 0 && (
        <div class="mt-6 rounded-2xl bg-gradient-to-br from-green-50/80 via-green-50/60 to-green-50/40 border border-green-200/70 p-5 md:p-6">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-base" aria-hidden="true">📋</span>
            <span class="text-xs md:text-sm font-bold text-deok-800 tracking-wide">
              30초 핵심 답
            </span>
          </div>
          <ul class="space-y-2.5">
            {bullets.map((b) => (
              <li class="flex items-start gap-3 text-sm md:text-base text-gray-800">
                <span class="mt-2 inline-block w-1.5 h-1.5 rounded-full bg-deok-500 shrink-0"></span>
                <span class="leading-relaxed">{b}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      {/* 출처 (신뢰 신호) */}
      {sourceLabel && (
        <div class="mt-5 flex items-center gap-2 text-xs text-gray-500">
          <svg aria-hidden="true" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
          <span class="font-semibold">출처</span>
          <span class="text-gray-300">·</span>
          <span class="line-clamp-1">{sourceLabel}</span>
        </div>
      )}

      {/* CTA - 강한 가치 제안 + 단계 안내 */}
      <div class="mt-7 md:mt-8 flex items-center justify-between gap-4 pt-5 border-t border-gray-100">
        <span class="text-xs md:text-sm text-gray-500 hidden sm:inline">
          진료 전에 읽어두면 도움이 되는 정보입니다
        </span>
        <span class="ml-auto inline-flex items-center gap-1.5 text-base font-bold text-deok-600 group-hover:text-deok-700 group-hover:gap-2.5 transition-all">
          자세히 읽기
          <span aria-hidden="true">→</span>
        </span>
      </div>
    </div>
  </a>
</section>
