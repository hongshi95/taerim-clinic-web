---
// 태림한의원의 강점 — 실제 진료 사진 + 깊이 있는 활자
const pillars = [
  {
    image: '/images/clinic/chuna-treatment.png',
    alt: '서조혁 원장의 추나 치료',
    label: '시그니처',
    title: '골타·추나·매선·약침·한약',
    body: '매주 일요일 서울로 새 치료법을 연구하러 다닙니다. 한방 통합 치료를 환자의 체질과 증상에 맞게 결합합니다.',
  },
  {
    image: '/images/clinic/consultation.png',
    alt: '태림한의원 환자 상담 장면',
    label: '진료 방식',
    title: '먼저 듣고, 함께 결정합니다',
    body: '환자분의 이야기를 끝까지 듣고, 환자분이 이해할 수 있는 언어로 진료 방향을 설명합니다. 과잉진료 하지 않습니다.',
  },
  {
    image: '/images/clinic/herbal-preparation.png',
    alt: '태림한의원 한약 제조 모습',
    label: '한약·체질',
    title: '체질을 보는 한약',
    body: '다이어트·보약·산전산후·소아성장·갱년기까지. 단일 처방이 아니라 환자의 체질·증상·생활을 함께 보고 처방합니다.',
  },
];
---

<section class="bg-white py-12 sm:py-16 md:py-24 border-y border-stone-100">
  <div class="v-container">
    <header class="mb-8 sm:mb-10 md:mb-14 max-w-2xl">
      <div class="text-[10px] sm:text-[11px] font-bold tracking-[0.2em] sm:tracking-[0.25em] uppercase text-green-900 mb-3 sm:mb-4">
        태림한의원의 강점
      </div>
      <h2 class="text-[1.7rem] sm:text-3xl md:text-4xl font-bold text-stone-900 tracking-tight leading-[1.2]">
        통증의 본질을 찾는, <span class="font-serif italic text-green-900">한방 통합 진료</span>
      </h2>
      <p class="mt-4 text-base text-stone-600 leading-relaxed">
        증상이 아닌 원인을 봅니다. 환자분의 이야기에서 단서를 찾습니다.
      </p>
    </header>

    <div class="grid gap-6 md:gap-8 md:grid-cols-3">
      {pillars.map((p) => (
        <article class="group">
          <div class="aspect-[4/3] overflow-hidden rounded-sm bg-stone-100 mb-5 shadow-md shadow-stone-900/10">
            <img
              src={p.image}
              alt={p.alt}
              class="w-full h-full object-cover object-center group-hover:scale-[1.02] transition-transform duration-500"
              loading="lazy"
              decoding="async"
              width="600"
              height="450"
            />
          </div>
          <div class="text-[10px] font-bold tracking-[0.25em] uppercase text-green-900 mb-2">
            {p.label}
          </div>
          <h3 class="text-lg md:text-xl font-bold text-stone-900 tracking-tight leading-snug">
            {p.title}
          </h3>
          <p class="mt-3 text-base md:text-[17px] text-stone-700 leading-[1.75]">
            {p.body}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
