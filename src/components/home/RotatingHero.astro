---
import { CLINIC } from '~/consts';
---

{/* 한의원 신뢰형 hero — 원장 portrait + 깊이 있는 활자. 모바일 우선 반응형. */}
<section class="bg-stone-50 relative overflow-hidden">
  {/* 옅은 종이 텍스처 — radial 1줄만 */}
  <div aria-hidden="true" class="absolute inset-0 -z-10 opacity-[0.5]">
    <div class="absolute -right-40 top-0 w-[600px] h-[600px] rounded-full bg-green-100/40 blur-3xl"></div>
  </div>

  <div class="v-container py-10 sm:py-14 md:py-20 lg:py-28">
    <div class="grid lg:grid-cols-[1.1fr_1fr] gap-8 sm:gap-10 lg:gap-16 items-center">
      {/* 좌측: 활자 */}
      <div class="order-2 lg:order-1">
        <div class="text-[10px] sm:text-[11px] font-bold tracking-[0.2em] sm:tracking-[0.25em] uppercase text-green-900 mb-4 sm:mb-6">
          {CLINIC.address.addressLocality} · 한의원
        </div>

        <h1 class="text-[1.85rem] sm:text-[2.4rem] md:text-5xl lg:text-[3.6rem] font-bold text-stone-900 leading-[1.2] md:leading-[1.15] tracking-tight">
          환자의 말을 듣고,
          <br />
          <span class="font-serif italic text-green-900 tracking-tight">통증의 본질</span>을 찾습니다.
        </h1>

        <p class="mt-5 sm:mt-7 md:mt-9 text-[17px] md:text-xl text-stone-700 leading-[1.8] md:leading-[1.85] max-w-xl">
          서조혁 원장은 매주 일요일 서울로 새 치료법을 연구하러 다닙니다. 골타·추나·매선·약침·한약을 환자의 체질과 증상에 맞게 결합합니다.
        </p>

        {/* CTA — green-800 + inline color 명시 (Tailwind text-white 누락 방지) */}
        <div class="mt-7 sm:mt-9 md:mt-10 flex flex-col sm:flex-row flex-wrap gap-3">
          {CLINIC.naverPlaceUrl ? (
            <a
              href={CLINIC.naverPlaceUrl}
              target="_blank"
              rel="noopener"
              style="color:#ffffff;background-color:#15803d;"
              class="group inline-flex items-center justify-center gap-2 hover:bg-green-900 font-semibold px-7 py-4 text-[17px] md:text-lg shadow-lg shadow-green-950/20 transition-all"
            >
              <span style="color:#ffffff;">진료 예약</span>
              <span aria-hidden="true" style="color:#ffffff;" class="transition-transform group-hover:translate-x-1">→</span>
            </a>
          ) : (
            <a
              href="/visit/"
              style="color:#ffffff;background-color:#15803d;"
              class="group inline-flex items-center justify-center gap-2 hover:bg-green-900 font-semibold px-7 py-4 text-[17px] md:text-lg shadow-lg shadow-green-950/20 transition-all"
            >
              <span style="color:#ffffff;">오시는길·진료시간</span>
              <span aria-hidden="true" style="color:#ffffff;" class="transition-transform group-hover:translate-x-1">→</span>
            </a>
          )}
          <a
            href="/about/"
            class="inline-flex items-center justify-center gap-2 bg-transparent border border-stone-300 hover:bg-stone-100 text-stone-800 font-semibold px-7 py-4 text-[17px] md:text-lg transition-all"
          >
            원장 진료 철학
          </a>
        </div>

        {/* 진료시간 미니 — 시니어 친화 크기 */}
        <dl class="mt-10 sm:mt-12 grid grid-cols-[max-content_1fr] gap-x-6 sm:gap-x-10 gap-y-3.5 text-[16px] md:text-lg border-t border-stone-200 pt-7 max-w-md">
          <dt class="text-stone-500 font-medium">평일 (월~금)</dt>
          <dd class="text-stone-900 font-medium tabular-nums">09:30 — 19:00</dd>
          <dt class="text-stone-500 font-medium">토요일</dt>
          <dd class="text-stone-900 font-medium tabular-nums">09:30 — 13:00</dd>
          <dt class="text-stone-500 font-medium">일·공휴일</dt>
          <dd class="text-stone-500">휴진</dd>
        </dl>
      </div>

      {/* 우측: 원장 portrait */}
      <figure class="order-1 lg:order-2 relative">
        <div class="relative aspect-[4/5] w-full max-w-[280px] sm:max-w-sm md:max-w-md mx-auto lg:max-w-none overflow-hidden rounded-sm shadow-2xl shadow-stone-900/25 ring-1 ring-stone-900/5">
          <img
            src="/images/clinic/director-seo.png"
            alt="태림한의원 서조혁 원장"
            class="w-full h-full object-cover object-center"
            loading="eager"
            decoding="async"
            width="540"
            height="675"
          />
          {/* 하단 캡션 — 어두운 글라스 overlay, inline color 명시 */}
          <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-stone-950/85 via-stone-950/40 to-transparent px-5 sm:px-6 py-5 sm:py-6">
            <div style="color:rgba(255,255,255,0.8);" class="text-[10px] uppercase tracking-[0.3em] font-medium">원장</div>
            <div style="color:#ffffff;" class="text-lg sm:text-xl md:text-2xl font-bold mt-1.5 tracking-tight">
              서조혁 <span style="color:rgba(255,255,255,0.7);" class="text-sm md:text-base font-medium">한의사</span>
            </div>
          </figcaption>
        </div>
      </figure>
    </div>
  </div>
</section>
