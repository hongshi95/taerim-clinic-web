---
import { SITE, ORGANIZATION } from '~/consts';

// 사이트 전체 공통 - 루트 페이지에서 1회 포함
const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    ORGANIZATION,
    {
      '@type': 'WebSite',
      '@id': `${SITE.url}/#website`,
      url: SITE.url,
      name: SITE.name,
      alternateName: [SITE.nameEn, '대구 태림한의원', '달서구 태림한의원', '대천동 태림한의원'],
      description: SITE.description,
      inLanguage: SITE.locale,
      publisher: { '@id': `${SITE.url}/#organization` },
      // SearchAction 제거: /search 공개페이지 실재 안 함 = 거짓 신호.
    },
  ],
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
