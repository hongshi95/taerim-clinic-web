---
import { SITE, SITE_NAVIGATION, CLINIC } from '~/consts';

interface Props {
  variant?: 'overlay' | 'solid';
}

const { variant = 'solid' } = Astro.props;
const currentPath = Astro.url.pathname;

const headerClass =
  variant === 'overlay'
    ? 'v-header-overlay'
    : 'sticky top-0 z-40 bg-white/80 backdrop-blur-md border-b border-gray-100';

const brandClass = variant === 'overlay' ? 'v-header-brand' : 'text-deok-700';
const subBrandClass =
  variant === 'overlay'
    ? 'v-header-link opacity-80'
    : 'text-gray-400';
const linkBaseClass =
  variant === 'overlay' ? 'v-header-link' : 'text-gray-600';
const linkHoverClass =
  variant === 'overlay'
    ? 'hover:opacity-80'
    : 'hover:text-deok-700 hover:bg-gray-50';
const linkActiveClass =
  variant === 'overlay'
    ? 'underline underline-offset-8 decoration-2'
    : 'text-deok-700 bg-deok-50';
const iconBtnClass =
  variant === 'overlay' ? 'v-header-icon' : 'hover:bg-gray-100';
---

<header class={headerClass}>
  <div class="v-container flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-2 shrink-0">
      <span
        class:list={[
          'text-xl font-bold tracking-tight whitespace-nowrap',
          brandClass,
        ]}
        style="font-family: var(--font-display);"
      >
        {SITE.name}
      </span>
      <span
        class:list={[
          'hidden xl:inline whitespace-nowrap text-xs font-medium tracking-widest uppercase',
          subBrandClass,
        ]}
        style="font-family: var(--font-display);"
      >
        {SITE.nameEn}
      </span>
    </a>

    <div class="flex items-center gap-2 md:gap-3">
      <nav class="hidden lg:flex items-center gap-1 text-sm">
        {SITE_NAVIGATION.map((item) => {
          const isActive =
            item.href === '/'
              ? currentPath === '/'
              : currentPath.startsWith(item.href);
          return (
            <a
              href={item.href}
              class:list={[
                'px-3 py-2 rounded-md font-medium transition-colors',
                linkBaseClass,
                isActive ? linkActiveClass : linkHoverClass,
              ]}
            >
              {item.label}
            </a>
          );
        })}
      </nav>

      {/* 고정 예약 CTA - 어느 페이지에서도 1클릭 예약 (데스크톱+모바일 항상 노출) */}
      {CLINIC.naverPlaceUrl && (
        <a
          href={CLINIC.naverPlaceUrl}
          target="_blank"
          rel="noopener"
          style="color:#ffffff;background-color:#15803d;"
          class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-[13px] sm:text-sm font-bold hover:bg-green-900 shadow-sm transition-colors whitespace-nowrap"
        >
          예약
          <span aria-hidden="true">→</span>
        </a>
      )}

      <button
        id="mobile-menu-btn"
        class:list={['lg:hidden p-2 rounded-md', iconBtnClass]}
        aria-label="메뉴 열기"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" x2="21" y1="6" y2="6"></line>
          <line x1="3" x2="21" y1="12" y2="12"></line>
          <line x1="3" x2="21" y1="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <nav
    id="mobile-menu"
    class="lg:hidden hidden border-t border-gray-100 bg-white"
  >
    <div class="v-container py-3 flex flex-col gap-1">
      {SITE_NAVIGATION.map((item) => (
        <a
          href={item.href}
          class="px-3 py-2 rounded-md text-sm font-medium text-gray-700 hover:bg-deok-50 hover:text-deok-700"
        >
          {item.label}
        </a>
      ))}
    </div>
  </nav>
</header>

<script is:inline>
  (() => {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    if (!btn || !menu) return;
    const setOpen = (open) => {
      menu.classList.toggle('hidden', !open);
      btn.setAttribute('aria-expanded', String(open));
      btn.setAttribute('aria-label', open ? '메뉴 닫기' : '메뉴 열기');
    };
    btn.addEventListener('click', () => setOpen(menu.classList.contains('hidden')));
    // 링크 클릭 시 메뉴 자동 닫기 (모바일 UX)
    menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
  })();
</script>
