---
import BreadcrumbSchema from '~/components/seo/BreadcrumbSchema.astro';

interface Crumb {
  name: string;
  href: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<BreadcrumbSchema items={[{ name: '홈', href: '/' }, ...items]} />

<nav class="v-container pt-4 pb-2 text-sm" aria-label="Breadcrumb">
  <ol class="flex items-center gap-2 text-gray-500 flex-wrap">
    <li>
      <a href="/" class="hover:text-deok-600">홈</a>
    </li>
    {items.map((item, i) => (
      <>
        <li aria-hidden="true" class="text-gray-300">/</li>
        <li>
          {i === items.length - 1 ? (
            <span class="text-gray-900 font-medium" aria-current="page">
              {item.name}
            </span>
          ) : (
            <a href={item.href} class="hover:text-deok-600">{item.name}</a>
          )}
        </li>
      </>
    ))}
  </ol>
</nav>
