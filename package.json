{
  "name": "taerim-clinic-web",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "태림한의원 - 대구 달서구 대천동 한의원 (Astro + Cloudflare)",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "sanitize": "node scripts/sanitize-mdx.mjs",
    "prebuild": "node scripts/sanitize-mdx.mjs",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "deploy": "npm run build && npm run cf:deploy",
    "audit": "npm run typecheck && npm run build",
    "setup": "npm install && npm run hooks:install && npm run secrets:install",
    "cf:deploy": "wrangler pages deploy dist --commit-message=\"local deploy\"",
    "cf:d1:migrate": "wrangler d1 execute taerimhan_db --file=./migrations/0001_initial.sql",
    "cf:d1:migrate:remote": "wrangler d1 execute taerimhan_db --remote --file=./migrations/0001_initial.sql",
    "cf:secrets:list": "wrangler pages secret list --project-name=taerim-clinic-web",
    "auto-deploy": "node scripts/auto-deploy.mjs",
    "hooks:install": "node scripts/install-hooks.mjs",
    "secrets": "node scripts/secrets-manage.mjs serve",
    "secrets:install": "node scripts/install-shortcut.mjs",
    "secrets:set": "node scripts/secrets-manage.mjs set",
    "secrets:check": "node scripts/secrets-manage.mjs check",
    "secrets:list": "node scripts/secrets-manage.mjs list",
    "secrets:remove": "node scripts/secrets-manage.mjs remove"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.10",
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/react": "^5.0.3",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.7",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "reading-time": "^1.5.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@cloudflare/workers-types": "^4.20260417.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.1",
    "astro-compress": "^2.4.1",
    "typescript": "^5.7.3",
    "wrangler": "^4.83.0"
  }
}
